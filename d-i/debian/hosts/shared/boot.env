# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared boot and runtime policy that is not just path metadata.

APT_REFRESH_LISTS_TIMEOUT="2min"
APT_REFRESH_LISTS_CONNECTIVITY_URL="https://deb.debian.org/debian/"
GRUB_DISPLAY_TERMINAL_INPUT="console"
GRUB_DISPLAY_TERMINAL_OUTPUT="gfxterm"
# Keep the GRUB menu at the 1024x768 firmware mode commonly referenced as
# legacy VGA 766. Linux still switches back to text payload so kernel KMS can
# choose the real runtime display mode cleanly.
GRUB_DISPLAY_GFXMODE="1024x768,auto"
GRUB_DISPLAY_GFXPAYLOAD_LINUX="text"
GRUB_DISPLAY_PRELOAD_MODULES="efi_gop efi_uga all_video video_bochs video_cirrus gfxterm"
GRUB_DISPLAY_FONT_SOURCE="/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf"
GRUB_DISPLAY_FONT_SIZE="28"

SECURE_BOOT_MOK_COMMON_NAME="Unattended Install Secure Boot"
SECURE_BOOT_MOK_COUNTRY="US"
SECURE_BOOT_MOK_STATE="California"
SECURE_BOOT_MOK_LOCALITY="San Francisco"
SECURE_BOOT_MOK_ORGANIZATION="Matthew Cramer"
SECURE_BOOT_MOK_ORG_UNIT="Installer Automation"
SECURE_BOOT_MOK_EMAIL="root@localhost"
SECURE_BOOT_MOK_RSA_BITS="2048"
SECURE_BOOT_MOK_VALID_DAYS="36500"

# D-Bus broker package-selection policy and system bus XML resource limits.
# Keep byte/fd quotas aligned with Debian's documented system-bus defaults;
# lower byte quotas can make dbus-broker treat normal root-owned boot traffic
# as a fatal per-UID quota violation.
DBUS_LIMIT_MAX_INCOMING_BYTES="133169152"
DBUS_LIMIT_MAX_OUTGOING_BYTES="133169152"
DBUS_LIMIT_MAX_MESSAGE_SIZE="33554432"
DBUS_LIMIT_MAX_MESSAGE_UNIX_FDS="16"
DBUS_LIMIT_MAX_INCOMING_UNIX_FDS="64"
DBUS_LIMIT_MAX_OUTGOING_UNIX_FDS="64"
DBUS_LIMIT_MAX_MATCH_RULES_PER_CONNECTION="512"
DBUS_LIMIT_MAX_NAMES_PER_CONNECTION="512"
DBUS_LIMIT_MAX_REPLIES_PER_CONNECTION="128"
DBUS_LIMIT_MAX_INCOMPLETE_CONNECTIONS="64"
DBUS_LIMIT_MAX_COMPLETED_CONNECTIONS="2048"
DBUS_LIMIT_MAX_CONNECTIONS_PER_USER="256"
DBUS_LIMIT_MAX_PENDING_SERVICE_STARTS="512"
DBUS_LIMIT_AUTH_TIMEOUT_MS="5000"
DBUS_LIMIT_PENDING_FD_TIMEOUT_MS="150000"
DBUS_LIMIT_SERVICE_START_TIMEOUT_MS="25000"
DBUS_LIMIT_REPLY_TIMEOUT_MS="120000"

# Keep dbus-broker close to vendor defaults and change only bounded resources.
DBUS_BROKER_TASKS_MAX="1024"
DBUS_BROKER_LIMIT_NOFILE="65536"
