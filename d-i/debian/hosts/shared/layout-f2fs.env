# shellcheck shell=sh
# shellcheck disable=SC2034,SC2153
# Shared F2FS/eMMC layout policy.

FS_LABEL_EFI="EFI"
FS_LABEL_BOOT="BOOT"
FS_LABEL_ROOT="ROOT"
FS_LABEL_HOME="HOME"
FS_LABEL_POOL="POOL"
FS_LABEL_VAR_LIB_SHSIGNED="SHIM_SIGNED"
FS_LABEL_VAR_LOG_JOURNAL="JOURNAL"

DEV_PART_EFI_MB="${SIZE_PART_EFI_MB}"
DEV_PART_BOOT_MB="${SIZE_PART_BOOT_MB}"
DEV_PART_ROOT_MB="${SIZE_PART_ROOT_MB}"
DEV_PART_HOME_MB="${SIZE_PART_HOME_MB}"
DEV_PART_POOL_MB="${SIZE_PART_POOL_MB}"
DEV_PART_VAR_LIB_SHSIGNED_MB="${SIZE_PART_VAR_LIB_SHSIGNED_MB}"
DEV_PART_VAR_LOG_JOURNAL_MB="${SIZE_PART_VAR_LOG_JOURNAL_MB}"
DEV_PART_RAW_SWAP_MB="${SIZE_PART_RAW_SWAP_MB}"
DEV_PART_RAW_ZRAM_MB="${SIZE_PART_RAW_ZRAM_MB}"

SIZE_MKFS_EXT4_BOOT_JOURNAL_MB="64"
SIZE_MKFS_EXT4_VAR_LIB_SHSIGNED_JOURNAL_MB="16"
SIZE_MKFS_EXT4_POOL_JOURNAL_MB="256"
SIZE_MKFS_EXT4_VAR_LOG_JOURNAL_JOURNAL_MB="128"

LUKS_NAME_VAR_LIB_SHSIGNED="secure-boot-mok"
LUKS_MAPPER_VAR_LIB_SHSIGNED="/dev/mapper/${LUKS_NAME_VAR_LIB_SHSIGNED}"

MNT_F2FS_BASE="rw,relatime,lazytime,background_gc=on,gc_merge,atgc,extent_cache,age_extent_cache,checkpoint_merge,nodiscard"
MNT_F2FS_COMPRESS_OPTS="compress_algorithm=lzo-rle,compress_log_size=2,compress_mode=fs,compress_cache,compress_extension=*,nocompress_extension=jpg,nocompress_extension=jpeg,nocompress_extension=png,nocompress_extension=gif,nocompress_extension=webp,nocompress_extension=mp4,nocompress_extension=mkv,nocompress_extension=mov,nocompress_extension=mp3,nocompress_extension=flac,nocompress_extension=zip,nocompress_extension=gz,nocompress_extension=xz,nocompress_extension=zst,nocompress_extension=deb,nocompress_extension=iso"
MNT_F2FS_ROOT_OPTS="${MNT_F2FS_BASE},${MNT_F2FS_COMPRESS_OPTS}"
MNT_F2FS_HOME_OPTS="${MNT_F2FS_BASE},${MNT_F2FS_COMPRESS_OPTS},${MNT_SEC_NODEV_NOSUID}"
MNT_EXT4_POOL_OPTS="${MNT_EXT_RELATIME},${MNT_SEC_NODEV_NOSUID}"
MNT_VAR_LIB_SHSIGNED_OPTS="${MNT_EXT_NOATIME},${MNT_SEC_NODEV_NOSUID_NOEXEC}"

MKFS_VFAT_EFI_OPTS="-F 32 -n ${FS_LABEL_EFI}"
# Keep /boot conservative for shim/GRUB readers and avoid newer ext4 metadata
# features that have historically caused compatibility pain on small boot tiers.
MKFS_EXT4_BOOT_OPTS="-F -L ${FS_LABEL_BOOT} -m 1 -b 4096 -I 256 -i 16384 -O has_journal,extent,huge_file,flex_bg,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg,^64bit,^metadata_csum,^metadata_csum_seed,^orphan_file -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_BOOT_JOURNAL_MB}"
MKFS_F2FS_ROOT_OPTS="-f -l ${FS_LABEL_ROOT} -O extra_attr,inode_checksum,sb_checksum,inode_crtime,lost_found,compression"
MKFS_F2FS_HOME_OPTS="-f -l ${FS_LABEL_HOME} -O extra_attr,inode_checksum,sb_checksum,inode_crtime,compression"
MKFS_EXT4_POOL_OPTS="-F -L ${FS_LABEL_POOL} -m 0 -b 4096 -I 256 -i 16384 -O has_journal,extent,huge_file,flex_bg,metadata_csum,64bit,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_POOL_JOURNAL_MB}"
MKFS_EXT4_VAR_LIB_SHSIGNED_OPTS="-F -L ${FS_LABEL_VAR_LIB_SHSIGNED} -m 0 -b 4096 -I 256 -i 16384 -O has_journal,extent,huge_file,flex_bg,metadata_csum,64bit,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_VAR_LIB_SHSIGNED_JOURNAL_MB}"
MKFS_EXT4_VAR_LOG_JOURNAL_OPTS="-F -L ${FS_LABEL_VAR_LOG_JOURNAL} -m 1 -b 4096 -I 256 -i 1048576 -O has_journal,extent,huge_file,flex_bg,metadata_csum,64bit,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_VAR_LOG_JOURNAL_JOURNAL_MB}"

# Let cryptsetup choose the LUKS2 sector size from the underlying block
# device. Forcing 512-byte encrypted sectors can fail on native-4K media with
# device-mapper "reload ioctl ... invalid argument" errors during luksOpen.
CRYPTSETUP_LUKS_VAR_LIB_SHSIGNED_OPTS="--type luks2 --label ${LUKS_NAME_VAR_LIB_SHSIGNED}"

GRUB_ROOT_FLAGS="rootfstype=f2fs rootwait rootflags=${MNT_F2FS_ROOT_OPTS}"
