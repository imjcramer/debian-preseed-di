# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared machine identity defaults for every installer profile.

# The installer generates SYSTEM_HOSTNAME once per run as
# ${SYSTEM_PREFIX}-### and persists it in runtime.env for later stages.

# Static DNS during Install
STATIC_NAMESERVERS_DEFAULT="1.1.1.1"

# Hostname & Domain
SYSTEM_PREFIX="LPL"
SYSTEM_DOMAIN="lan.icramer.com"
