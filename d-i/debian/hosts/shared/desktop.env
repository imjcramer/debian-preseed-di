# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared Labwc desktop policy. Only the desktop role consumes these knobs.

LABWC_DESKTOP_ENABLE="true"
LABWC_DESKTOP_DEFAULT_TARGET="graphical.target"
LABWC_DESKTOP_SESSION_NAME="Labwc"
LABWC_DESKTOP_SESSION_COMMENT="Labwc Wayland session"
LABWC_DESKTOP_SESSION_COMMAND="/usr/local/bin/labwc-session"
LABWC_DESKTOP_DEFAULTS_FILE="/etc/default/labwc-desktop"
LABWC_WORKSPACE_COUNT="4"

LABWC_GREETER_VT="1"
LABWC_GREETER_USER_CANDIDATES="_greetd greeter greetd"
LABWC_GREETER_COMMAND="/usr/local/bin/labwc-greeter-session"

LABWC_WALLPAPER_PATH="/usr/share/backgrounds/labwc/wallpapers/wall-labwall2-1920x1080.png"
LABWC_LOCK_BACKGROUND_PATH="/usr/share/backgrounds/labwc/wallpapers/lock-labwall2-1920x1080.png"
LABWC_GREETER_BACKGROUND_PATH="/usr/share/backgrounds/labwc/wallpapers/regreet-labwall2-1920x1080.png"

LABWC_TERMINAL_PRIMARY="foot"
LABWC_TERMINAL_FALLBACK="kitty"
LABWC_LAUNCHER_COMMAND="labwc-wofi --show drun"
LABWC_MENU_COMMAND="labwc-wofi --show drun"
LABWC_FILE_MANAGER_COMMAND="thunar"
LABWC_AUDIO_CONTROL_COMMAND="pavucontrol"
LABWC_DISPLAY_CONTROL_COMMAND="wdisplays"
LABWC_CALENDAR_COMMAND="labwc-calendar"
LABWC_BRIGHTNESS_CONTROL_COMMAND="labwc-brightness-control"
LABWC_POWER_SETTINGS_COMMAND="labwc-power-settings"
LABWC_KEYBOARD_LAYOUTS="us se"
LABWC_KEYBOARD_DEFAULT_LAYOUT="us"

LABWC_OUTPUT_POLICY="external-only"
LABWC_OUTPUT_INTERNAL_PREFIXES="eDP LVDS DSI"
# Leave the external mode unset to select the connector's preferred/native mode.
# Set width, height, and optionally refresh to force a specific mode.
LABWC_OUTPUT_EXTERNAL_PREFERRED_WIDTH=""
LABWC_OUTPUT_EXTERNAL_PREFERRED_HEIGHT=""
LABWC_OUTPUT_EXTERNAL_PREFERRED_REFRESH_HZ=""
LABWC_OUTPUT_FALLBACK_REFRESH_HZ="60"
LABWC_OUTPUT_SCALE="1"
LABWC_OUTPUT_INTERNAL_SCALE="1"
LABWC_OUTPUT_EXTERNAL_SCALE="1.80"
LABWC_OUTPUT_HOTPLUG_DEBOUNCE_SECONDS="2"

LABWC_ENABLE_WAYBAR="true"
LABWC_ENABLE_KANSHI="true"
LABWC_ENABLE_MAKO="true"
LABWC_ENABLE_SWAYIDLE="true"
LABWC_ENABLE_SWAYBG="true"
LABWC_ENABLE_POLKIT_AGENT="true"
LABWC_ENABLE_XDG_DESKTOP_PORTAL="true"
LABWC_ENABLE_CRYSTAL_DOCK="true"

LABWC_IDLE_LOCK_SECONDS="900"
LABWC_IDLE_DPMS_SECONDS="1200"
LABWC_IDLE_SUSPEND_SECONDS="0"
LABWC_WAYBAR_START_DELAY_SECONDS="0"

LABWC_CRYSTAL_DOCK_COMMAND="crystal-dock"
LABWC_CRYSTAL_DOCK_RESTART_DELAY_SECONDS="1"

LABWC_CURSOR_THEME="Adwaita"
LABWC_CURSOR_SIZE="20"
LABWC_GTK_THEME="Adwaita"
LABWC_GDK_BACKEND="wayland"
LABWC_QT_QPA_PLATFORM="wayland"
LABWC_SDL_VIDEODRIVER="wayland"
LABWC_CLUTTER_BACKEND="wayland"
LABWC_ICON_THEME="Papirus-Dark"
LABWC_QT_PLATFORMTHEME="qt6ct"
LABWC_QT_STYLE_OVERRIDE="adwaita-dark"

# Optional Podman addon policy. These values are consumed only when the
# addon/podman class is selected.
PODMAN_USER="podsvc"
PODMAN_USER_COMMENT="Managed Podman service account"
PODMAN_USER_HOME="/data/accounts/podman"
PODMAN_USER_SHELL="/usr/sbin/nologin"
PODMAN_USER_LOCK=1
PODMAN_USER_LINGER=1
PODMAN_USER_DAEMON=1
PODMAN_USER_DOCKER_HOST=0
PODMAN_USER_CONTAINER_HOST=0
PODMAN_USER_STRIP_GROUPS=1
PODMAN_USER_ALLOWED_GROUPS=""
PODMAN_SERVICE_SLICE_ENABLE=1
PODMAN_SERVICE_SLICE_CPU_WEIGHT=200
PODMAN_SERVICE_SLICE_IO_WEIGHT=200
PODMAN_SERVICE_SLICE_TASKS_MAX=8192
PODMAN_ENABLE_ROOTLESS_SYSCTL=1
PODMAN_ROOTLESS_USERNS_CLONE=1
PODMAN_ROOTLESS_MAX_USER_NAMESPACES=28633
PODMAN_ROOTLESS_STATE_BASE="/pool/podman"
PODMAN_USER_CONFIG_BASE="/data/config/podman"
PODMAN_ROOTLESS_TMP_BASE="/pool/podman"
PODMAN_TLS_PKI_BASE="/data/pki/tls/podman"
PODMAN_TLS_KEY_PASSPHRASE_FILE="/data/pki/tls/podman/private/passphrase.txt"
PODMAN_STORAGE_DRIVER="overlay"
PODMAN_RUNTIME="crun"
PODMAN_EVENTS_LOGGER="journald"
PODMAN_CGROUP_MANAGER="systemd"
PODMAN_NETWORK_BACKEND="netavark"
PODMAN_FIREWALL_DRIVER="nftables"
PODMAN_ROOTLESS_NETWORK_CMD="pasta"
PODMAN_CONTAINERS_LOG_DRIVER="journald"
PODMAN_CONTAINERS_CGROUPNS="private"
PODMAN_CONTAINERS_UTSNS="private"
PODMAN_SHORT_NAME_MODE="disabled"
PODMAN_UNQUALIFIED_SEARCH_REGISTRIES=""
PODMAN_BLOCKED_REGISTRIES=""
PODMAN_ROOTLESS_BUILDAH_ISOLATION="rootless"
PODMAN_TLS_ENABLE=1
PODMAN_TLS_REGISTRIES="127.0.0.1:5000,localhost:5000"
PODMAN_TLS_CA_COMMON_NAME="Podman Local Registry CA"
PODMAN_TLS_CA_DAYS=3650
PODMAN_TLS_CERT_DAYS=825
PODMAN_TLS_RSA_BITS=4096
