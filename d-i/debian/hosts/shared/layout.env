# shellcheck shell=sh
# shellcheck disable=SC2034,SC2153
# Shared layout-policy primitives: mount-security fragments, tmpfs policy,
# common mount fragments, and ephemeral dm-crypt backing.

# Initial value before runtime sizing clamps the fallback swap partition.
SWAP_SIZE_MIB="${SIZE_PART_SWAP_MIN_MIB}"

MNT_SEC_NODEV="nodev"
MNT_SEC_NODEV_NOSUID="nodev,nosuid"
MNT_SEC_NODEV_NOSUID_NOEXEC="nodev,nosuid,noexec"
MNT_EXT_BASE="rw,lazytime,nodiscard,errors=remount-ro"
MNT_EXT_RELATIME="${MNT_EXT_BASE},relatime"
MNT_EXT_NOATIME="${MNT_EXT_BASE},noatime"
MNT_EFI_BASE="rw,fmask=0077,dmask=0077,${MNT_SEC_NODEV_NOSUID},noexec"
MNT_BOOT_OPTS="${MNT_EXT_NOATIME},${MNT_SEC_NODEV_NOSUID_NOEXEC}"
MNT_EFI_OPTS="${MNT_EFI_BASE}"
MNT_VAR_LOG_JOURNAL_OPTS="${MNT_EXT_NOATIME},${MNT_SEC_NODEV_NOSUID_NOEXEC},x-systemd.requires-mounts-for=${DIR_VAR_LOG}"
MNT_TMP_BASE_OPTS="rw,nodev,nosuid,mode=1777,huge=within_size"
MNT_DEV_SHM_BASE_OPTS="rw,${MNT_SEC_NODEV_NOSUID_NOEXEC},mode=1777,huge=within_size"
MNT_VAR_LOG_TMPFS_BASE_OPTS="rw,${MNT_SEC_NODEV_NOSUID_NOEXEC},mode=0755"

# debconf executes package config helpers from /var/cache/debconf/tmp.ci during
# base install and later apt/dpkg runs, so /var/cache must stay executable.
MNT_VAR_CACHE_TMPFS_BASE_OPTS="rw,${MNT_SEC_NODEV_NOSUID},mode=0755"
MNT_APT_LISTS_TMPFS_BASE_OPTS="rw,${MNT_SEC_NODEV_NOSUID_NOEXEC},mode=0755"
MNT_COREDUMP_TMPFS_BASE_OPTS="rw,${MNT_SEC_NODEV_NOSUID_NOEXEC},mode=0755"
MNT_DATA_RUN_TMPFS_BASE_OPTS="rw,${MNT_SEC_NODEV_NOSUID_NOEXEC},mode=0755"
MNT_TMP_OPTS="${MNT_TMP_BASE_OPTS},size=${SIZE_TMPFS_TMP_PCT}%"
MNT_DEV_SHM_OPTS="${MNT_DEV_SHM_BASE_OPTS},size=${SIZE_TMPFS_DEV_SHM_PCT}%"
MNT_VAR_LOG_TMPFS_OPTS="${MNT_VAR_LOG_TMPFS_BASE_OPTS},size=${SIZE_TMPFS_VAR_LOG_PCT}%"
MNT_VAR_CACHE_TMPFS_OPTS="${MNT_VAR_CACHE_TMPFS_BASE_OPTS},size=${SIZE_TMPFS_VAR_CACHE_PCT}%"
MNT_APT_LISTS_TMPFS_OPTS="${MNT_APT_LISTS_TMPFS_BASE_OPTS},size=${SIZE_TMPFS_APT_LISTS_PCT}%"
MNT_COREDUMP_TMPFS_OPTS="${MNT_COREDUMP_TMPFS_BASE_OPTS},size=${SIZE_TMPFS_COREDUMP_PCT}%"
MNT_DATA_RUN_TMPFS_OPTS="${MNT_DATA_RUN_TMPFS_BASE_OPTS},size=${SIZE_TMPFS_DATA_RUN_MIB}M,x-systemd.requires-mounts-for=${DIR_DATA}"

DMCRYPT_EPHEMERAL_CIPHER="aes-xts-plain64"
DMCRYPT_EPHEMERAL_KEY_SIZE="512"
DMCRYPT_EPHEMERAL_HASH="sha256"
DMCRYPT_RANDOM_KEY_FILE="/dev/urandom"
ZRAM_BACKING_MAPPER_NAME="zram-writeback"
SWAP_FALLBACK_MAPPER_NAME="swap-fallback"
SWAP_FALLBACK_PRIORITY="10"
