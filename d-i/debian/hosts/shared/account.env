# shellcheck shell=sh
# shellcheck disable=SC2016,SC2034
# Shared human-account and SSH bootstrap policy.

ROOT_LOGIN="true"
ROOT_PASSWORD_CRYPTED=""
ACCOUNT_USERNAME="mcramer"
ACCOUNT_FULLNAME="Matthew Cramer"
ACCOUNT_PASSWORD_CRYPTED=""
ACCOUNT_DEFAULT_GROUPS="audio cdrom video sudo"
ACCOUNT_HOME="/home/${ACCOUNT_USERNAME}"

# User-facing home path contract. Storage families decide whether these paths
# are plain directories or dedicated mount/subvolume targets.
DIR_HOME_DESKTOP="${ACCOUNT_HOME}/Desktop"
DIR_HOME_DOCUMENTS="${ACCOUNT_HOME}/Documents"
DIR_HOME_DOWNLOADS="${ACCOUNT_HOME}/Downloads"
DIR_HOME_MUSIC="${ACCOUNT_HOME}/Music"
DIR_HOME_PUBLIC="${ACCOUNT_HOME}/Public"
DIR_HOME_PICTURES="${ACCOUNT_HOME}/Pictures"
DIR_HOME_TEMPLATES="${ACCOUNT_HOME}/Templates"
DIR_HOME_VIDEOS="${ACCOUNT_HOME}/Videos"
DIR_HOME_WORKSPACE="${ACCOUNT_HOME}/Workspace"

# SSH server bootstrap assets. These files are fetched from the served repo only
# when the selected installer classes include addon/ssh.
SSH_PUBLIC_KEY_SOURCE="ssh/lan_ed25519.pub"
SSHD_CONFIG_SOURCE="ssh/sshd_config"
SSH_USER_CONFIG_SOURCE="ssh/config"
SSH_PUBLIC_KEY_MAX_BYTES="4096"
SSH_CONFIG_MAX_BYTES="65536"
SSH_AUTHORIZED_KEYS_TARGET="${ACCOUNT_HOME}/.ssh/authorized_keys"
SSH_USER_CONFIG_TARGET="${ACCOUNT_HOME}/.ssh/config"
