# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared runtime paths, installer state paths, and target destination contract.

# Base environment
ENV_FRONTEND="noninteractive"
ENV_PATH_DEFAULT="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
DEBIAN_FRONTEND="${ENV_FRONTEND}"
PATH="${ENV_PATH_DEFAULT}"
