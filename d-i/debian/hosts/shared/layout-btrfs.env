# shellcheck shell=sh
# shellcheck disable=SC2034,SC2153
# Shared Btrfs/XFS layout policy for NVMe and VM profiles.

FS_LABEL_EFI="EFI"
FS_LABEL_BOOT="BOOT"
FS_LABEL_ROOT="ROOT"
FS_LABEL_HOME="HOME"
FS_LABEL_OPT="OPT"
FS_LABEL_DATA="DATA"
FS_LABEL_POOL="POOL"
FS_LABEL_VAR_TMP="VAR_TMP"
FS_LABEL_VAR_LIB_SHSIGNED="SHIM_SIGNED"
FS_LABEL_VAR_LOG_JOURNAL="JOURNAL"

DEV_PART_EFI_MB="${SIZE_PART_EFI_MB}"
DEV_PART_BOOT_MB="${SIZE_PART_BOOT_MB}"
DEV_PART_ROOT_MB="${SIZE_PART_ROOT_MB}"
DEV_PART_HOME_MB="${SIZE_PART_HOME_MB}"
DEV_PART_OPT_MB="${SIZE_PART_OPT_MB}"
DEV_PART_DATA_MB="${SIZE_PART_DATA_MB}"
DEV_PART_POOL_MB="${SIZE_PART_POOL_MB}"
DEV_PART_VAR_TMP_MB="${SIZE_PART_VAR_TMP_MB}"
DEV_PART_VAR_LIB_SHSIGNED_MB="${SIZE_PART_VAR_LIB_SHSIGNED_MB}"
DEV_PART_VAR_LOG_JOURNAL_MB="${SIZE_PART_VAR_LOG_JOURNAL_MB}"
DEV_PART_RAW_SWAP_MB="${SIZE_PART_RAW_SWAP_MB}"
DEV_PART_RAW_ZRAM_MB="${SIZE_PART_RAW_ZRAM_MB}"

SIZE_MKFS_EXT4_BOOT_JOURNAL_MB="64"
SIZE_MKFS_EXT4_VAR_LIB_SHSIGNED_JOURNAL_MB="16"
SIZE_XFS_LOGBSIZE="256k"
SIZE_XFS_DATA_ALLOCSIZE="64k"
SIZE_XFS_POOL_ALLOCSIZE="256k"
SIZE_MKFS_EXT4_VAR_TMP_JOURNAL_MB="256"
SIZE_MKFS_EXT4_VAR_LOG_JOURNAL_JOURNAL_MB="256"

LUKS_NAME_VAR_LIB_SHSIGNED="secure-boot-mok"
LUKS_MAPPER_VAR_LIB_SHSIGNED="/dev/mapper/${LUKS_NAME_VAR_LIB_SHSIGNED}"

MNT_BTRFS_BASE="rw,relatime,lazytime,compress=zstd:1,space_cache=v2,nodiscard"
MNT_BTRFS_USER_RESTRICTED="${MNT_BTRFS_BASE},${MNT_SEC_NODEV_NOSUID_NOEXEC}"
MNT_BTRFS_ROOT_OPTS="${MNT_BTRFS_BASE},subvol=@"
MNT_ROOT_HOME_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV_NOSUID},subvol=@root"
MNT_OPT_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV},subvol=@opt"
MNT_SRV_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV_NOSUID},subvol=@srv"
MNT_USR_LOCAL_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV},subvol=@usr_local"
MNT_VAR_SPOOL_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV_NOSUID},subvol=@var_spool"
MNT_BTRFS_HOME_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV_NOSUID},subvol=@home"
MNT_HOME_DOWNLOADS_OPTS="${MNT_BTRFS_USER_RESTRICTED},subvol=@home_downloads"
MNT_HOME_PUBLIC_OPTS="${MNT_BTRFS_USER_RESTRICTED},subvol=@home_public"
MNT_HOME_PICTURES_OPTS="${MNT_BTRFS_USER_RESTRICTED},subvol=@home_pictures"
MNT_HOME_WORKSPACE_OPTS="${MNT_BTRFS_BASE},${MNT_SEC_NODEV_NOSUID},subvol=@home_workspace"
MNT_XFS_DATA_OPTS="rw,relatime,lazytime,inode64,largeio,logbufs=8,logbsize=${SIZE_XFS_LOGBSIZE},allocsize=${SIZE_XFS_DATA_ALLOCSIZE},prjquota,uquota,nodiscard,nodev,nosuid"
MNT_XFS_POOL_OPTS="rw,noatime,lazytime,inode64,largeio,logbufs=8,logbsize=${SIZE_XFS_LOGBSIZE},allocsize=${SIZE_XFS_POOL_ALLOCSIZE},prjquota,uquota,nodiscard,nodev,nosuid"
MNT_VAR_TMP_OPTS="${MNT_EXT_RELATIME},${MNT_SEC_NODEV_NOSUID_NOEXEC}"
MNT_VAR_LIB_SHSIGNED_OPTS="${MNT_EXT_NOATIME},${MNT_SEC_NODEV_NOSUID_NOEXEC}"

MKFS_VFAT_EFI_OPTS="-F 32 -n ${FS_LABEL_EFI}"
# Keep /boot conservative for shim/GRUB readers and avoid newer ext4 metadata
# features that have historically caused compatibility pain on small boot tiers.
MKFS_EXT4_BOOT_OPTS="-F -L ${FS_LABEL_BOOT} -m 1 -b 4096 -I 256 -i 16384 -O has_journal,extent,huge_file,flex_bg,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg,^64bit,^metadata_csum,^metadata_csum_seed,^orphan_file -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_BOOT_JOURNAL_MB}"
MKFS_BTRFS_ROOT_OPTS="-f -L ${FS_LABEL_ROOT} --checksum crc32c --data single --metadata dup --nodesize 16384 --features extref,skinny-metadata,no-holes --runtime-features free-space-tree"
MKFS_BTRFS_HOME_OPTS="-f -L ${FS_LABEL_HOME} --checksum crc32c --data single --metadata dup --nodesize 16384 --features extref,skinny-metadata,no-holes --runtime-features free-space-tree"
MKFS_BTRFS_OPT_OPTS="-f -L ${FS_LABEL_OPT} --checksum crc32c --data single --metadata dup --nodesize 16384 --features extref,skinny-metadata,no-holes --runtime-features free-space-tree"
MKFS_XFS_DATA_OPTS="-f -K -L ${FS_LABEL_DATA} -m crc=1,finobt=1,reflink=0,rmapbt=1,bigtime=1,inobtcount=1 -n ftype=1 -i size=512,sparse=1,nrext64=1"
MKFS_XFS_POOL_OPTS="-f -K -L ${FS_LABEL_POOL} -m crc=1,finobt=1,reflink=1,rmapbt=1,bigtime=1,inobtcount=1 -n ftype=1 -i size=2048,sparse=1,nrext64=1"
MKFS_EXT4_VAR_TMP_OPTS="-F -L ${FS_LABEL_VAR_TMP} -m 0 -b 4096 -I 256 -i 8192 -O has_journal,extent,huge_file,flex_bg,metadata_csum,64bit,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_VAR_TMP_JOURNAL_MB}"
MKFS_EXT4_VAR_LIB_SHSIGNED_OPTS="-F -L ${FS_LABEL_VAR_LIB_SHSIGNED} -m 0 -b 4096 -I 256 -i 16384 -O has_journal,extent,huge_file,flex_bg,metadata_csum,64bit,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_VAR_LIB_SHSIGNED_JOURNAL_MB}"
MKFS_EXT4_VAR_LOG_JOURNAL_OPTS="-F -L ${FS_LABEL_VAR_LOG_JOURNAL} -m 1 -b 4096 -I 256 -i 1048576 -O has_journal,extent,huge_file,flex_bg,metadata_csum,64bit,dir_index,dir_nlink,extra_isize,sparse_super,large_file,filetype,uninit_bg -E lazy_itable_init=0,lazy_journal_init=0,discard -J size=${SIZE_MKFS_EXT4_VAR_LOG_JOURNAL_JOURNAL_MB}"

# Let cryptsetup choose the LUKS2 sector size from the underlying block
# device. Forcing 512-byte encrypted sectors can fail on native-4K media with
# device-mapper "reload ioctl ... invalid argument" errors during luksOpen.
CRYPTSETUP_LUKS_VAR_LIB_SHSIGNED_OPTS="--type luks2 --label ${LUKS_NAME_VAR_LIB_SHSIGNED}"

GRUB_ROOT_FLAGS="rootfstype=btrfs rootflags=subvol=@,relatime,lazytime,compress=zstd:1,space_cache=v2,nodiscard"
ROOT_STAGE="/mnt/btrfs-root"
HOME_STAGE="/mnt/btrfs-home"
OPT_STAGE="/mnt/btrfs-opt"
