# shellcheck shell=sh
# shellcheck disable=SC2034
# Concrete VM server profile.

NFT_PROFILE="default"
NFT_SERVICES="none"
# NFTABLES_LOG_LEVEL options: none, error, warning, info, debug
NFTABLES_LOG_LEVEL="none"
# ZRAM_LOG_LEVEL options: none, error, warning, info, debug
ZRAM_LOG_LEVEL="error"
# SYSTEMD_LOG_LEVEL options: none, error, warning, info, debug
SYSTEMD_LOG_LEVEL="error"

# Wi-Fi PSK Security
WIFI_PSK_SECURITY="sae"
PRESEED_NETWORK_ETHERNET_IFACE="preeth0"
PRESEED_NETWORK_WIFI_IFACE="prewifi0"

# IPv4 Ethernet & Wi-Fi
IPV4_STATIC_RANGE="192.168.50.181/28"
IPV4_CIDR="24"
IPV4_GATEWAY="192.168.50.1"
IPV4_DNS="192.168.50.1"

# IPv6 Ethernet & Wi-Fi
IPV6_STATIC_RANGE="2001:9b1:29fd:4e00::78/125"
IPV6_PREFIXLEN="64"
IPV6_GATEWAY="2001:9b1:29fd:4e00::1"
IPV6_DNS="2001:9b1:29fd:4e00::1"

TMPFS_VAR_LOG="true"
TMPFS_VAR_CACHE="true"
TMPFS_VAR_LIB_APT_LISTS="true"
TMPFS_DEV_SHM="true"
TMPFS_DATA_RUN="true"
TMPFS_SYSTEMD_COREDUMP="true"

SECURE_BOOT_STATE_MODE="luks"

PARTMAN_RECIPE_NAME="vm-layout-server"

DEFAULT_EFI_SLOT="1"
DEFAULT_BOOT_SLOT="2"
DEFAULT_ROOT_SLOT="3"
DEFAULT_HOME_SLOT="4"
DEFAULT_OPT_SLOT="5"
DEFAULT_DATA_SLOT="6"
DEFAULT_POOL_SLOT="7"
DEFAULT_VAR_TMP_SLOT="8"
DEFAULT_VAR_LIB_SHSIGNED_SLOT="9"
DEFAULT_VAR_LOG_JOURNAL_SLOT="10"
DEFAULT_RAW_SWAP_SLOT="11"
DEFAULT_RAW_ZRAM_SLOT="12"

SIZE_LAYOUT_SAFETY_MARGIN_MB="256"
SIZE_PART_EFI_MB="512"
SIZE_PART_BOOT_MB="1024"
SIZE_PART_ROOT_MB="10240"
SIZE_PART_HOME_MB="2048"
SIZE_PART_OPT_MB="1024"
SIZE_PART_DATA_MB="1024"
SIZE_PART_POOL_MB="262144"
SIZE_PART_VAR_TMP_MB="2048"
SIZE_PART_VAR_LIB_SHSIGNED_MB="100"
SIZE_PART_VAR_LOG_JOURNAL_MB="1024"
SIZE_PART_RAW_SWAP_MB="2048"
SIZE_PART_RAW_ZRAM_MB="2048"
SIZE_PART_ROOT_TARGET_MB="32768"
SIZE_PART_HOME_TARGET_MB="81920"
SIZE_PART_OPT_TARGET_MB="8192"
SIZE_PART_DATA_TARGET_MB="102400"
SIZE_PART_VAR_TMP_TARGET_MB="16384"
SIZE_PART_RAW_ZRAM_MAX_MB="32768"
SIZE_PART_RAW_ZRAM_DISK_DIVISOR="16"
SIZE_PART_RAW_ZRAM_BUDGET_DIVISOR="4"
SIZE_PART_SWAP_MIN_MIB="1024"
SIZE_PART_SWAP_MAX_MIB="16384"
SIZE_PART_SWAP_RAM_DIVISOR="4"
SIZE_PART_SWAP_LAYOUT_DIVISOR="12"
SIZE_TMPFS_TMP_PCT="20"
SIZE_TMPFS_DEV_SHM_PCT="25"
SIZE_TMPFS_VAR_LOG_PCT="2"
SIZE_TMPFS_VAR_CACHE_PCT="5"
SIZE_TMPFS_APT_LISTS_PCT="5"
SIZE_TMPFS_COREDUMP_PCT="5"
SIZE_TMPFS_DATA_RUN_MIB="100"

ZRAM_PCT="100"
ZRAM_MIN_MIB="2048"
ZRAM_MAX_MIB="8192"
ZRAM_MEM_LIMIT_PCT="70"
ZRAM_WRITEBACK_LIMIT_PCT="20"
ZRAM_COMPRESSION_ALGORITHM="lz4"
ZRAM_ALGORITHM_PARAMS=""
ZRAM_TIER1_ENABLE="1"
ZRAM_TIER1_ALGORITHM="lzo-rle"
ZRAM_TIER1_PRIORITY="1"
ZRAM_TIER1_LEVEL="0"
ZRAM_TIER1_THRESHOLD_BYTES="2048"
ZRAM_TIER1_MAX_PAGES_NORMAL="65536"
ZRAM_TIER1_MAX_PAGES_PRESSURE="131072"
ZRAM_TIER1_MAX_PAGES_EMERGENCY="262144"
ZRAM_TIER2_ENABLE="1"
ZRAM_TIER2_ALGORITHM="zstd"
ZRAM_TIER2_PRIORITY="2"
ZRAM_TIER2_LEVEL="3"
ZRAM_TIER2_THRESHOLD_BYTES="3000"
ZRAM_TIER2_MAX_PAGES_NORMAL="32768"
ZRAM_TIER2_MAX_PAGES_PRESSURE="65536"
ZRAM_TIER2_MAX_PAGES_EMERGENCY="131072"
ZRAM_TIER3_ENABLE="1"
ZRAM_TIER3_ALGORITHM="zstd"
ZRAM_TIER3_PRIORITY="3"
ZRAM_TIER3_LEVEL="1"
ZRAM_TIER3_THRESHOLD_BYTES="3584"
ZRAM_TIER3_MAX_PAGES_NORMAL="0"
ZRAM_TIER3_MAX_PAGES_PRESSURE="4096"
ZRAM_TIER3_MAX_PAGES_EMERGENCY="16384"
ZRAM_SWAP_DEVICE="/dev/zram0"
ZRAM_SWAP_PRIORITY="300"
ZRAM_MAX_COMP_STREAMS="0"
ZRAM_COMPRESSED_WRITEBACK="1"
ZRAM_WRITEBACK_ENABLE="1"
ZRAM_HOT_AGE_SEC="300"
ZRAM_IDLE_AGE_SEC="3600"
ZRAM_PRESSURE_IDLE_AGE_SEC="1200"
ZRAM_EMERGENCY_IDLE_AGE_SEC="300"
ZRAM_WRITEBACK_BATCH_SIZE="512"
ZRAM_WRITEBACK_LIMIT_ENABLE="1"
ZRAM_DAILY_WRITEBACK_LIMIT=""
ZRAM_IDLE_WRITEBACK_ENABLE="1"
ZRAM_PRESSURE_ENABLE="1"
ZRAM_PRESSURE_MEM_AVAILABLE_PCT="12"
ZRAM_EMERGENCY_MEM_AVAILABLE_PCT="6"
ZRAM_PRESSURE_SOME_AVG10_THRESHOLD="0.50"
ZRAM_PRESSURE_FULL_AVG10_THRESHOLD="0.30"
ZRAM_EMERGENCY_SOME_AVG10_THRESHOLD="8.00"
ZRAM_EMERGENCY_FULL_AVG10_THRESHOLD="1.50"
ZRAM_MIN_FREE_MEMORY="0"
ZRAM_WRITEBACK_MIN_REMAINING_PAGES="1"
ZRAM_COLD_TIER_ENABLE="1"
ZRAM_COLD_TIER_RECOMPRESS_ENABLE="1"
ZRAM_COLD_TIER_WRITEBACK_ENABLE="1"
ZRAM_COLD_TIER_COMPACT_ENABLE="1"
ZRAM_COLD_TIER_MIN_ZRAM_FILL_PCT="60"
ZRAM_COLD_TIER_MIN_COLD_PAGES="512"
ZRAM_COLD_TIER_MIN_IDLE_PAGES="256"
ZRAM_COLD_TIER_MIN_HUGE_IDLE_PAGES="1"
ZRAM_COLD_TIER_MIN_HUGE_PAGES="1"
ZRAM_COLD_TIER_MIN_INCOMPRESSIBLE_PAGES="1"
ZRAM_COLD_TIER_RECOMPRESS_IDLE_MAX_PAGES="131072"
ZRAM_COLD_TIER_RECOMPRESS_HUGE_IDLE_MAX_PAGES="65536"
ZRAM_COLD_TIER_RECOMPRESS_HUGE_MAX_PAGES="4096"
ZRAM_COLD_TIER_WRITEBACK_INCOMPRESSIBLE_MAX_PAGES="16384"
ZRAM_COLD_TIER_WRITEBACK_SPEC_CHUNK_PAGE_LIMIT="2048"
ZRAM_IDLE_WRITEBACK_INTERVAL="30min"
ZRAM_IDLE_WRITEBACK_RANDOMIZED_DELAY="5min"
ZRAM_COLD_TIER_INTERVAL="2h"
ZRAM_COLD_TIER_RANDOMIZED_DELAY="10min"
ZRAM_MAINTENANCE_MEMORY_HIGH="128M"
ZRAM_MAINTENANCE_MEMORY_MAX="256M"
ZRAM_MAINTENANCE_IO_WRITE_BANDWIDTH_MAX="16M"
ZRAM_MAINTENANCE_PAGE_INDEXES=""

# Bootprofile-specific sysctl overlay values rendered into profiles/*/50-*.conf.
# Keep these values numeric; late_command validates each key before rendering.

# Balanced profile.
# VM reclaim, zram-backed swap, and compaction.
SYSCTL_PROFILE_BALANCED_SWAPPINESS="135"
SYSCTL_PROFILE_BALANCED_PAGE_CLUSTER="0"
SYSCTL_PROFILE_BALANCED_VFS_CACHE_PRESSURE="90"
SYSCTL_PROFILE_BALANCED_WATERMARK_BOOST_FACTOR="0"
SYSCTL_PROFILE_BALANCED_WATERMARK_SCALE_FACTOR="140"
SYSCTL_PROFILE_BALANCED_COMPACTION_PROACTIVENESS="20"
SYSCTL_PROFILE_BALANCED_EXTFRAG_THRESHOLD="500"
SYSCTL_PROFILE_BALANCED_ZONE_RECLAIM_MODE="0"
# Dirty writeback budget for volatile caches and installer-managed storage.
SYSCTL_PROFILE_BALANCED_DIRTY_BACKGROUND_BYTES="33554432"
SYSCTL_PROFILE_BALANCED_DIRTY_BYTES="134217728"
SYSCTL_PROFILE_BALANCED_DIRTY_EXPIRE_CENTISECS="900"
SYSCTL_PROFILE_BALANCED_DIRTY_WRITEBACK_CENTISECS="150"
SYSCTL_PROFILE_BALANCED_DIRTYTIME_EXPIRE_SECONDS="43200"
SYSCTL_PROFILE_BALANCED_STAT_INTERVAL="10"
# File descriptor, AIO, and inotify pressure limits.
SYSCTL_PROFILE_BALANCED_AIO_MAX_NR="2097152"
SYSCTL_PROFILE_BALANCED_INOTIFY_MAX_USER_INSTANCES="1024"
SYSCTL_PROFILE_BALANCED_INOTIFY_MAX_USER_WATCHES="524288"
SYSCTL_PROFILE_BALANCED_INOTIFY_MAX_QUEUED_EVENTS="65536"
# Network accept queues and connection churn.
SYSCTL_PROFILE_BALANCED_SOMAXCONN="65535"
SYSCTL_PROFILE_BALANCED_NETDEV_MAX_BACKLOG="250000"
SYSCTL_PROFILE_BALANCED_TCP_MAX_SYN_BACKLOG="32768"
SYSCTL_PROFILE_BALANCED_TCP_FASTOPEN="3"
SYSCTL_PROFILE_BALANCED_TCP_KEEPALIVE_TIME="300"
SYSCTL_PROFILE_BALANCED_TCP_FIN_TIMEOUT="25"

# Hardened profile.
# VM reclaim, zram-backed swap, and compaction.
SYSCTL_PROFILE_HARDENED_SWAPPINESS="150"
SYSCTL_PROFILE_HARDENED_PAGE_CLUSTER="0"
SYSCTL_PROFILE_HARDENED_VFS_CACHE_PRESSURE="90"
SYSCTL_PROFILE_HARDENED_WATERMARK_BOOST_FACTOR="0"
SYSCTL_PROFILE_HARDENED_WATERMARK_SCALE_FACTOR="140"
SYSCTL_PROFILE_HARDENED_COMPACTION_PROACTIVENESS="20"
SYSCTL_PROFILE_HARDENED_EXTFRAG_THRESHOLD="700"
SYSCTL_PROFILE_HARDENED_ZONE_RECLAIM_MODE="0"
# Dirty writeback budget for volatile caches and installer-managed storage.
SYSCTL_PROFILE_HARDENED_DIRTY_BACKGROUND_BYTES="16777216"
SYSCTL_PROFILE_HARDENED_DIRTY_BYTES="67108864"
SYSCTL_PROFILE_HARDENED_DIRTY_EXPIRE_CENTISECS="600"
SYSCTL_PROFILE_HARDENED_DIRTY_WRITEBACK_CENTISECS="75"
SYSCTL_PROFILE_HARDENED_DIRTYTIME_EXPIRE_SECONDS="3600"
SYSCTL_PROFILE_HARDENED_STAT_INTERVAL="5"
# File descriptor, AIO, and inotify pressure limits.
SYSCTL_PROFILE_HARDENED_AIO_MAX_NR="1048576"
SYSCTL_PROFILE_HARDENED_INOTIFY_MAX_USER_INSTANCES="1024"
SYSCTL_PROFILE_HARDENED_INOTIFY_MAX_USER_WATCHES="262144"
SYSCTL_PROFILE_HARDENED_INOTIFY_MAX_QUEUED_EVENTS="32768"
# Network accept queues and connection churn.
SYSCTL_PROFILE_HARDENED_SOMAXCONN="32768"
SYSCTL_PROFILE_HARDENED_NETDEV_MAX_BACKLOG="125000"
SYSCTL_PROFILE_HARDENED_TCP_MAX_SYN_BACKLOG="16384"
SYSCTL_PROFILE_HARDENED_TCP_FASTOPEN="1"
SYSCTL_PROFILE_HARDENED_TCP_KEEPALIVE_TIME="300"
SYSCTL_PROFILE_HARDENED_TCP_FIN_TIMEOUT="20"

# Performance profile.
# VM reclaim, zram-backed swap, and compaction.
SYSCTL_PROFILE_PERFORMANCE_SWAPPINESS="110"
SYSCTL_PROFILE_PERFORMANCE_PAGE_CLUSTER="0"
SYSCTL_PROFILE_PERFORMANCE_VFS_CACHE_PRESSURE="90"
SYSCTL_PROFILE_PERFORMANCE_WATERMARK_BOOST_FACTOR="5000"
SYSCTL_PROFILE_PERFORMANCE_WATERMARK_SCALE_FACTOR="140"
SYSCTL_PROFILE_PERFORMANCE_COMPACTION_PROACTIVENESS="20"
SYSCTL_PROFILE_PERFORMANCE_EXTFRAG_THRESHOLD="400"
SYSCTL_PROFILE_PERFORMANCE_ZONE_RECLAIM_MODE="0"
# Dirty writeback budget for volatile caches and installer-managed storage.
SYSCTL_PROFILE_PERFORMANCE_DIRTY_BACKGROUND_BYTES="67108864"
SYSCTL_PROFILE_PERFORMANCE_DIRTY_BYTES="268435456"
SYSCTL_PROFILE_PERFORMANCE_DIRTY_EXPIRE_CENTISECS="1200"
SYSCTL_PROFILE_PERFORMANCE_DIRTY_WRITEBACK_CENTISECS="200"
SYSCTL_PROFILE_PERFORMANCE_DIRTYTIME_EXPIRE_SECONDS="86400"
SYSCTL_PROFILE_PERFORMANCE_STAT_INTERVAL="15"
# File descriptor, AIO, and inotify pressure limits.
SYSCTL_PROFILE_PERFORMANCE_AIO_MAX_NR="4194304"
SYSCTL_PROFILE_PERFORMANCE_INOTIFY_MAX_USER_INSTANCES="2048"
SYSCTL_PROFILE_PERFORMANCE_INOTIFY_MAX_USER_WATCHES="1048576"
SYSCTL_PROFILE_PERFORMANCE_INOTIFY_MAX_QUEUED_EVENTS="131072"
# Network accept queues and connection churn.
SYSCTL_PROFILE_PERFORMANCE_SOMAXCONN="131072"
SYSCTL_PROFILE_PERFORMANCE_NETDEV_MAX_BACKLOG="500000"
SYSCTL_PROFILE_PERFORMANCE_TCP_MAX_SYN_BACKLOG="65535"
SYSCTL_PROFILE_PERFORMANCE_TCP_FASTOPEN="3"
SYSCTL_PROFILE_PERFORMANCE_TCP_KEEPALIVE_TIME="600"
SYSCTL_PROFILE_PERFORMANCE_TCP_FIN_TIMEOUT="15"

BOOTPROFILE_DEFAULT="balanced"
BOOTPROFILE_HARDENED="hardened"
BOOTPROFILE_PERFORMANCE="performance"
GRUB_DEFAULT_ENTRY="installer-linux-dynamic"
GRUB_INITRAMFS_FLAGS="initramfs_options=mode=0755,huge=within_size"
GRUB_SYSTEMD_MASK_FLAGS=""
GRUB_SECURITY_CORE_FLAGS="vsyscall=none apparmor=1 lsm=landlock,lockdown,yama,integrity,apparmor,bpf module.sig_enforce=1 pti=on randomize_kstack_offset=on"
GRUB_CGROUP_FLAGS="systemd.unified_cgroup_hierarchy=1 cgroup_no_v1=all"
GRUB_MEMORY_CORE_FLAGS="page_alloc.shuffle=1 slab_nomerge=1 zswap.enabled=0 zswap.max_pool_percent=0 transparent_hugepage=always transparent_hugepage_shmem=within_size transparent_hugepage_tmpfs=within_size"
GRUB_HARDENING_FLAGS="noresume systemd.show_status=auto random.trust_cpu=off"
GRUB_PROFILE_DEFAULT_FLAGS="audit=1 audit_backlog_limit=8192 loglevel=3 mitigations=auto lockdown=integrity nmi_watchdog=0 psi=1 workqueue.power_efficient=1 preempt=voluntary hardened_usercopy=1 init_on_alloc=1 init_on_free=1"
GRUB_PROFILE_HARDENED_FLAGS="audit=1 audit_backlog_limit=16384 loglevel=2 mitigations=auto lockdown=confidentiality nmi_watchdog=0 psi=1 workqueue.power_efficient=1 preempt=voluntary hardened_usercopy=2 init_on_alloc=1 init_on_free=1"
GRUB_PROFILE_PERFORMANCE_FLAGS="audit=1 audit_backlog_limit=4096 loglevel=4 mitigations=auto lockdown=integrity nmi_watchdog=0 psi=1 workqueue.power_efficient=0 preempt=voluntary hardened_usercopy=1 init_on_alloc=0 init_on_free=0"
