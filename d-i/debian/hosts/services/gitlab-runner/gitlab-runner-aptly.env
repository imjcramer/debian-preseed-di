# shellcheck shell=sh
# shellcheck disable=SC2034
# Dedicated Aptly runner. Secret values may be literal strings or absolute
# file paths that contain the secret payload.

GITLAB_RUNNER_APTLY_USERNAME="glab-aptly"
GITLAB_RUNNER_APTLY_GITLAB_URL="https://gitlab.com"
GITLAB_RUNNER_APTLY_TOKEN=""
GITLAB_RUNNER_APTLY_NAME="aptly"
GITLAB_RUNNER_APTLY_TAGS="aptly,publish,internal"
GITLAB_RUNNER_APTLY_METRICS_ADDRESS="127.0.0.1:9271"
GITLAB_RUNNER_APTLY_DOCKER_USERNS_MODE="keep-id"
GITLAB_RUNNER_APTLY_IMAGE="localhost/gitlab-runner-aptly:trixie"
GITLAB_RUNNER_APTLY_IMAGE_BUILD_MODE="containerfile"
GITLAB_RUNNER_APTLY_IMAGE_CONTEXT="/pool/aptly"
GITLAB_RUNNER_APTLY_IMAGE_CONTAINERFILE="/pool/aptly/Containerfile"
GITLAB_RUNNER_APTLY_BUILDS_DIR="/pool/build/aptly"
GITLAB_RUNNER_APTLY_GITLAB_CACHE_DIR="/pool/cache/aptly/gitlab"
GITLAB_RUNNER_APTLY_CACHE_ROOT="/pool/cache/aptly/tools"
GITLAB_RUNNER_APTLY_ALLOWED_IMAGES="localhost/gitlab-runner-aptly:trixie,debian:*,ubuntu:*,python:*,node:*,golang:*,openjdk:*,maven:*,gradle:*,ruby:*,rust:*,gitlab/glab:*,gcr.io/kaniko-project/executor:v1.24.0-debug@sha256:2562c4fe551399514277ffff7dcca9a3b1628c4ea38cb017d7286dc6ea52f4cd,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*"
GITLAB_RUNNER_APTLY_ALLOWED_SERVICES="postgres:*,redis:*,mysql:*,mariadb:*,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*"
GITLAB_RUNNER_APTLY_EXTRA_VOLUMES="/pool/aptly:/pool/aptly:rw"

GITLAB_RUNNER_APTLY_R2_BUCKET_NAME="cf-aptly-r2-prod"
GITLAB_RUNNER_APTLY_R2_ENDPOINT_URL=""
GITLAB_RUNNER_APTLY_R2_ACCOUNT_ID=""
GITLAB_RUNNER_APTLY_R2_ACCESS_KEY_ID=""
GITLAB_RUNNER_APTLY_R2_SECRET_ACCESS_KEY=""
GITLAB_RUNNER_APTLY_GPG_SIGNING_KEY=""
GITLAB_RUNNER_APTLY_GPG_SIGNING_PASSPHRASE=""

GITLAB_RUNNER_APTLY_R2_ENDPOINT_NAME="r2"
GITLAB_RUNNER_APTLY_R2_PREFIX="debian/"
GITLAB_RUNNER_APTLY_R2_STORAGE_CLASS="STANDARD"
GITLAB_RUNNER_APTLY_R2_DEBUG="false"
GITLAB_RUNNER_APTLY_ARCHITECTURES="amd64"
GITLAB_RUNNER_APTLY_DOWNLOAD_CONCURRENCY="4"
GITLAB_RUNNER_APTLY_SBUILD_ARCH="amd64"
GITLAB_RUNNER_APTLY_SBUILD_SUITES="stable testing unstable"
GITLAB_RUNNER_APTLY_SBUILD_MIRROR="https://deb.debian.org/debian"
GITLAB_RUNNER_APTLY_SBUILD_TARBALL_DIR="/pool/cache/aptly/tools/sbuild"
GITLAB_RUNNER_APTLY_PUBLISH_COMPONENT="main"
GITLAB_RUNNER_APTLY_PUBLISH_DISTRIBUTION=""
GITLAB_RUNNER_APTLY_PUBLISH_ORIGIN="GitLab CI"
GITLAB_RUNNER_APTLY_PUBLISH_LABEL="GitLab CI"
GITLAB_RUNNER_APTLY_PUBLISH_ACQUIRE_BY_HASH="true"
GITLAB_RUNNER_APTLY_SKIP_CONTENTS="false"

GITLAB_RUNNER_APTLY_CHANNELS="stable testing"
GITLAB_RUNNER_APTLY_CHANNEL_STATE_DIR="/pool/aptly/.managed/channels"

GITLAB_RUNNER_APTLY_CHANNEL_STABLE_DISTRIBUTION="stable"
GITLAB_RUNNER_APTLY_CHANNEL_STABLE_ENDPOINT="s3:r2:"
GITLAB_RUNNER_APTLY_CHANNEL_STABLE_PREFIX="."
GITLAB_RUNNER_APTLY_CHANNEL_STABLE_KEEP_SNAPSHOTS="2"
GITLAB_RUNNER_APTLY_CHANNEL_STABLE_MAX_AGE_DAYS="0"

GITLAB_RUNNER_APTLY_CHANNEL_TESTING_DISTRIBUTION="testing"
GITLAB_RUNNER_APTLY_CHANNEL_TESTING_ENDPOINT="s3:r2:"
GITLAB_RUNNER_APTLY_CHANNEL_TESTING_PREFIX="."
GITLAB_RUNNER_APTLY_CHANNEL_TESTING_KEEP_SNAPSHOTS="3"
GITLAB_RUNNER_APTLY_CHANNEL_TESTING_MAX_AGE_DAYS="14"
