# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared GitLab Runner and rootless Podman policy for the optional
# service/gitlab-runner install path.

GITLAB_RUNNER_ENV_DIR="/etc/default/gitlab-runner"
GITLAB_RUNNER_STATE_BASE="/data/config/runners"
GITLAB_RUNNER_USER_HOME_BASE="/data/services/usr"
GITLAB_RUNNER_PODMAN_CONFIG_BASE="/data/config/podman"
GITLAB_RUNNER_PODMAN_STATE_BASE="/pool/podman"
GITLAB_RUNNER_PODMAN_TMP_BASE="${GITLAB_RUNNER_PODMAN_STATE_BASE}"

GITLAB_RUNNER_CONTAINER_BUILDS_DIR="/builds"
GITLAB_RUNNER_CONTAINER_CACHE_DIR="/cache"
GITLAB_RUNNER_CONFIG_BASENAME="config.toml"
GITLAB_RUNNER_SYSTEM_ID_BASENAME=".runner_system_id"
GITLAB_RUNNER_SERVICE_UMASK="0077"
GITLAB_RUNNER_CONFIG_GROUP="devops"
GITLAB_RUNNER_CONTROL_DIR_MODE="0750"
GITLAB_RUNNER_CONTROL_FILE_MODE="0640"

GITLAB_RUNNER_CONCURRENT="3"
GITLAB_RUNNER_LIMIT="2"
GITLAB_RUNNER_REQUEST_CONCURRENCY="2"
GITLAB_RUNNER_OUTPUT_LIMIT="42768"
GITLAB_RUNNER_CACHE_MAX_UPLOADED_ARCHIVE_SIZE="1073741824"
GITLAB_RUNNER_CHECK_INTERVAL="3"
GITLAB_RUNNER_CONNECTION_MAX_AGE="15m"
GITLAB_RUNNER_START_TIMEOUT_SECONDS="1200"
GITLAB_RUNNER_SHUTDOWN_TIMEOUT="30"
GITLAB_RUNNER_LOG_LEVEL="info"
GITLAB_RUNNER_LOG_FORMAT="json"
GITLAB_RUNNER_RUN_UNTAGGED="false"
GITLAB_RUNNER_LOCKED="true"
GITLAB_RUNNER_CLEAN_GIT_CONFIG="true"
GITLAB_RUNNER_DEBUG_TRACE_DISABLED="true"
GITLAB_RUNNER_CUSTOM_BUILD_DIR_ENABLED="false"
GITLAB_RUNNER_REQUIRE_PODMAN="true"
GITLAB_RUNNER_VERIFY_ACTIVE="true"
GITLAB_RUNNER_SERVICE_START_WAIT_SECONDS="45"
GITLAB_RUNNER_SERVICE_STABLE_SECONDS="3"

GITLAB_RUNNER_MEMORY_HIGH="14G"
GITLAB_RUNNER_MEMORY_MAX="15G"
GITLAB_RUNNER_CPU_QUOTA="200%"
GITLAB_RUNNER_CPU_WEIGHT="100"
GITLAB_RUNNER_TASKS_MAX="2048"
GITLAB_RUNNER_SERVICES_LIMIT="5"

GITLAB_RUNNER_DOCKER_TLS_VERIFY="false"
GITLAB_RUNNER_DOCKER_PRIVILEGED="false"
GITLAB_RUNNER_DOCKER_PULL_POLICY="if-not-present"
GITLAB_RUNNER_ALLOWED_PULL_POLICIES="always,if-not-present"
GITLAB_RUNNER_DOCKER_SECURITY_OPTS="no-new-privileges:true"
GITLAB_RUNNER_CAP_DROP="NET_RAW"
GITLAB_RUNNER_ALLOWED_KANIKO_IMAGE="gcr.io/kaniko-project/executor:v1.24.0-debug@sha256:2562c4fe551399514277ffff7dcca9a3b1628c4ea38cb017d7286dc6ea52f4cd"

GITLAB_RUNNER_ENABLE_CCACHE="true"
GITLAB_RUNNER_ENABLE_SCCACHE="true"
GITLAB_RUNNER_CCACHE_MAX_SIZE="30G"
GITLAB_RUNNER_SCCACHE_CACHE_SIZE="40G"
GITLAB_RUNNER_CCACHE_COMPRESS="true"
GITLAB_RUNNER_CCACHE_COMPRESSLEVEL="6"
GITLAB_RUNNER_CCACHE_COMPILERCHECK="content"
GITLAB_RUNNER_CACHE_PRUNE_DAYS="30"
GITLAB_RUNNER_NETWORK_TIMEOUT="900"
GITLAB_RUNNER_CACHE_DIR_NAMES='
xdg
cargo
rustup
ccache
sccache
pip
pipx
uv
pypoetry
python
npm
npx
pnpm
pnpx
yarn
corepack
node-gyp
bun
deno
go-build
gomod
gradle
maven
ivy2
sbt
coursier
nuget
dotnet
composer
bundle
git-lfs
pre-commit
ms-playwright
cypress
conan2
vcpkg
vcpkg/downloads
vcpkg/bincache
meson
bazel
bazelisk
cuda
zig
julia
r
renv
stack
cabal
mix
hex
rebar3
terraform
helm
helm/cache
helm/config
helm/data
ansible
turbo
nx
kaniko
buildah
podman
'

GITLAB_PODMAN_USER_COMMENT_PREFIX="Managed GitLab Runner service account"
GITLAB_PODMAN_USER_SHELL="/usr/sbin/nologin"
GITLAB_PODMAN_USER_LOCK="1"
GITLAB_PODMAN_USER_LINGER="1"
GITLAB_PODMAN_USER_DAEMON="1"
GITLAB_PODMAN_USER_DOCKER_HOST="0"
GITLAB_PODMAN_USER_CONTAINER_HOST="0"
GITLAB_PODMAN_USER_STRIP_GROUPS="1"
GITLAB_PODMAN_USER_ALLOWED_GROUPS=""
GITLAB_PODMAN_SERVICE_SLICE_ENABLE="1"
GITLAB_PODMAN_SERVICE_SLICE_CPU_WEIGHT="200"
GITLAB_PODMAN_SERVICE_SLICE_IO_WEIGHT="200"
GITLAB_PODMAN_SERVICE_SLICE_TASKS_MAX="8192"
GITLAB_PODMAN_ENABLE_ROOTLESS_SYSCTL="1"
GITLAB_PODMAN_ROOTLESS_USERNS_CLONE="1"
GITLAB_PODMAN_ROOTLESS_MAX_USER_NAMESPACES="28633"
GITLAB_PODMAN_STORAGE_DRIVER="overlay"
GITLAB_PODMAN_RUNTIME="crun"
GITLAB_PODMAN_EVENTS_LOGGER="journald"
GITLAB_PODMAN_CGROUP_MANAGER="systemd"
GITLAB_PODMAN_NETWORK_BACKEND="netavark"
GITLAB_PODMAN_FIREWALL_DRIVER="nftables"
GITLAB_PODMAN_ROOTLESS_NETWORK_CMD="pasta"
GITLAB_PODMAN_CONTAINERS_LOG_DRIVER="journald"
GITLAB_PODMAN_CONTAINERS_CGROUPNS="private"
GITLAB_PODMAN_CONTAINERS_UTSNS="private"
GITLAB_PODMAN_SHORT_NAME_MODE="disabled"
GITLAB_PODMAN_UNQUALIFIED_SEARCH_REGISTRIES="docker.io,ghcr.io,registry.gitlab.com"
GITLAB_PODMAN_BLOCKED_REGISTRIES=""
GITLAB_PODMAN_ROOTLESS_BUILDAH_ISOLATION="rootless"
GITLAB_PODMAN_TLS_ENABLE="0"
GITLAB_PODMAN_TLS_REGISTRIES=""
GITLAB_PODMAN_TLS_CA_COMMON_NAME="GitLab Runner Podman CA"
GITLAB_PODMAN_TLS_CA_DAYS="3650"
GITLAB_PODMAN_TLS_CERT_DAYS="825"
GITLAB_PODMAN_TLS_RSA_BITS="4096"
