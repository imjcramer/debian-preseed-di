# shellcheck shell=sh
# shellcheck disable=SC2034
# Dedicated Bazel runner. Secret values may be literal strings or absolute file
# paths that contain the secret payload. Use a writable BuildBuddy org API key
# if CI should upload new cache artifacts instead of reading cache hits only.

GITLAB_RUNNER_BAZEL_USERNAME="glab-bazel"
GITLAB_RUNNER_BAZEL_GITLAB_URL="https://gitlab.com"
GITLAB_RUNNER_BAZEL_TOKEN=""
GITLAB_RUNNER_BAZEL_NAME="bazel"
GITLAB_RUNNER_BAZEL_TAGS="bazel,release,internal"
GITLAB_RUNNER_BAZEL_METRICS_ADDRESS="127.0.0.1:9273"
GITLAB_RUNNER_BAZEL_IMAGE="docker.io/library/debian:trixie-slim"
GITLAB_RUNNER_BAZEL_IMAGE_BUILD_MODE="none"
GITLAB_RUNNER_BAZEL_BUILDS_DIR="/pool/build/runners/bazel"
GITLAB_RUNNER_BAZEL_GITLAB_CACHE_DIR="/pool/cache/runners/bazel/gitlab"
GITLAB_RUNNER_BAZEL_CACHE_ROOT="/pool/cache/runners/bazel/tools"
GITLAB_RUNNER_BAZEL_ALLOWED_IMAGES="docker.io/library/debian:trixie-slim,debian:*,ubuntu:*,python:*,node:*,golang:*,openjdk:*,maven:*,gradle:*,ruby:*,rust:*,gitlab/glab:*,gcr.io/kaniko-project/executor:v1.24.0-debug@sha256:2562c4fe551399514277ffff7dcca9a3b1628c4ea38cb017d7286dc6ea52f4cd,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*,quay.io/buildah/*"
GITLAB_RUNNER_BAZEL_ALLOWED_SERVICES="postgres:*,redis:*,mysql:*,mariadb:*,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*"
GITLAB_RUNNER_BAZEL_EXTRA_VOLUMES="/usr/local/bin/bazelisk:/usr/local/bin/bazel:ro,/usr/local/bin/bazelisk:/usr/local/bin/bazelisk:ro"

GITLAB_RUNNER_BUILDBUDDY_API=""
GITLAB_RUNNER_BUILDBUDDY_ENDPOINT="grpcs://remote.buildbuddy.io"
GITLAB_RUNNER_BUILDBUDDY_RESULTS_URL="https://app.buildbuddy.io/invocation/"
