# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared build runner. Keep the metrics address aligned with
# gitlab-runner-task.env because both stanzas share one user service.

GITLAB_RUNNER_BUILD_USERNAME="glab-user"
GITLAB_RUNNER_BUILD_GITLAB_URL="https://gitlab.com"
GITLAB_RUNNER_BUILD_TOKEN=""
GITLAB_RUNNER_BUILD_NAME="build"
GITLAB_RUNNER_BUILD_TAGS="build,release,internal"
GITLAB_RUNNER_BUILD_METRICS_ADDRESS="127.0.0.1:9272"
GITLAB_RUNNER_BUILD_IMAGE="docker.io/library/debian:trixie-slim"
GITLAB_RUNNER_BUILD_IMAGE_BUILD_MODE="none"
GITLAB_RUNNER_BUILD_BUILDS_DIR="/pool/build/runners/build"
GITLAB_RUNNER_BUILD_GITLAB_CACHE_DIR="/pool/cache/runners/build/gitlab"
GITLAB_RUNNER_BUILD_CACHE_ROOT="/pool/cache/runners/build/tools"
GITLAB_RUNNER_BUILD_ALLOWED_IMAGES="docker.io/library/debian:trixie-slim,debian:*,ubuntu:*,python:*,node:*,golang:*,openjdk:*,maven:*,gradle:*,ruby:*,rust:*,gitlab/glab:*,gcr.io/kaniko-project/executor:v1.24.0-debug@sha256:2562c4fe551399514277ffff7dcca9a3b1628c4ea38cb017d7286dc6ea52f4cd,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*"
GITLAB_RUNNER_BUILD_ALLOWED_SERVICES="postgres:*,redis:*,mysql:*,mariadb:*,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*"
GITLAB_RUNNER_BUILD_EXTRA_VOLUMES=""
