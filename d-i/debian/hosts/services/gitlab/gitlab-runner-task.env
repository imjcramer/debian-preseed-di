# shellcheck shell=sh
# shellcheck disable=SC2034
# Shared task runner. Keep the metrics address aligned with
# gitlab-runner-build.env because both stanzas share one user service.

GITLAB_RUNNER_TASK_USERNAME="glab-user"
GITLAB_RUNNER_TASK_GITLAB_URL="https://gitlab.com"
GITLAB_RUNNER_TASK_TOKEN=""
GITLAB_RUNNER_TASK_NAME="task"
GITLAB_RUNNER_TASK_TAGS="task,automation,internal"
GITLAB_RUNNER_TASK_METRICS_ADDRESS="127.0.0.1:9272"
GITLAB_RUNNER_TASK_IMAGE="docker.io/library/debian:trixie-slim"
GITLAB_RUNNER_TASK_IMAGE_BUILD_MODE="none"
GITLAB_RUNNER_TASK_BUILDS_DIR="/pool/build/runners/task"
GITLAB_RUNNER_TASK_GITLAB_CACHE_DIR="/pool/cache/runners/task/gitlab"
GITLAB_RUNNER_TASK_CACHE_ROOT="/pool/cache/runners/task/tools"
GITLAB_RUNNER_TASK_ALLOWED_IMAGES="docker.io/library/debian:trixie-slim,debian:*,ubuntu:*,python:*,node:*,golang:*,openjdk:*,maven:*,gradle:*,ruby:*,rust:*,gitlab/glab:*,gcr.io/kaniko-project/executor:v1.24.0-debug@sha256:2562c4fe551399514277ffff7dcca9a3b1628c4ea38cb017d7286dc6ea52f4cd,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*,quay.io/buildah/*"
GITLAB_RUNNER_TASK_ALLOWED_SERVICES="postgres:*,redis:*,mysql:*,mariadb:*,registry.gitlab.com/registry-containers/**/*:*,registry.gitlab.com/registry-containers/**/*@sha256:*"
GITLAB_RUNNER_TASK_EXTRA_VOLUMES=""
