#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'
shopt -s inherit_errexit 2>/dev/null || true

PROG="${0##*/}"
ENV_DIR="/etc/default/gitlab-runner"
SHARED_ENV="${ENV_DIR}/gitlab-runner-shared.env"

systemctl_actions=(
  cat
  daemon-reload
  disable
  enable
  is-active
  is-enabled
  list-dependencies
  list-unit-files
  list-units
  reload
  restart
  reset-failed
  show
  start
  status
  stop
  try-restart
)

info() {
  printf '%s: %s\n' "$PROG" "$*" >&2
}

die() {
  printf '%s: %s\n' "$PROG" "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

validate_username() {
  local label="$1"
  local value="$2"
  [[ "$value" =~ ^[a-z_][a-z0-9_-]*$ ]] || die "${label} has an invalid user name: ${value:-unset}"
}

validate_absolute_path() {
  local label="$1"
  local value="$2"
  [[ "$value" == /* ]] || die "${label} must be an absolute path: ${value:-unset}"
  [[ "$value" != "/" ]] || die "${label} must not be /"
  [[ "$value" != *$'\n'* && "$value" != *$'\r'* ]] || die "${label} contains control characters"
  [[ "$value" != *".."* ]] || die "${label} must not contain .."
}

load_env_file() {
  local path="$1"
  [[ -r "$path" ]] || die "env file is not readable: $path"
  [[ ! -L "$path" ]] || die "env file must not be a symlink: $path"
  # shellcheck disable=SC1090
  . "$path"
}

load_shared_env() {
  [[ "${SHARED_ENV_LOADED:-false}" == "true" ]] && return 0
  load_env_file "$SHARED_ENV"
  validate_absolute_path GITLAB_RUNNER_STATE_BASE "${GITLAB_RUNNER_STATE_BASE:-}"
  validate_absolute_path GITLAB_RUNNER_USER_HOME_BASE "${GITLAB_RUNNER_USER_HOME_BASE:-}"
  SHARED_ENV_LOADED=true
}

load_user_context() {
  local passwd_entry _passwd_name _passwd_passwd _passwd_gid _passwd_gecos passwd_home _passwd_shell
  load_shared_env
  validate_username requested_user "$requested_user"

  context_user="$requested_user"
  context_state_dir="${GITLAB_RUNNER_STATE_BASE}/${context_user}"
  context_home="${GITLAB_RUNNER_USER_HOME_BASE}/${context_user}"
  validate_absolute_path context_state_dir "$context_state_dir"
  validate_absolute_path context_home "$context_home"
  [[ -d "$context_state_dir" ]] || die "managed runner state is missing: ${context_state_dir}"

  passwd_entry="$(getent passwd "$context_user" || true)"
  [[ -n "$passwd_entry" ]] || die "managed user is missing from passwd: ${context_user}"
  IFS=: read -r _passwd_name _passwd_passwd context_uid _passwd_gid _passwd_gecos passwd_home _passwd_shell <<<"$passwd_entry"
  [[ "$passwd_home" == "$context_home" ]] || die "managed user home drifted from ${context_home}: ${passwd_home}"

  context_runtime="/run/user/${context_uid}"
  context_bus="unix:path=${context_runtime}/bus"
  context_xdg_config_home="${context_home}/.config"
  context_xdg_data_home="${context_home}/.local/share"
  context_xdg_cache_home="${context_home}/.cache"
  context_xdg_state_home="${context_home}/.local/state"
}

run_privileged() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
    return $?
  fi
  require_cmd sudo
  sudo -- "$@"
}

run_as_user() {
  if [[ "$(id -un)" == "$context_user" ]]; then
    env \
      HOME="$context_home" \
      XDG_CONFIG_HOME="$context_xdg_config_home" \
      XDG_DATA_HOME="$context_xdg_data_home" \
      XDG_CACHE_HOME="$context_xdg_cache_home" \
      XDG_STATE_HOME="$context_xdg_state_home" \
      XDG_RUNTIME_DIR="$context_runtime" \
      DBUS_SESSION_BUS_ADDRESS="$context_bus" \
      PATH="$PATH" \
      "$@"
    return $?
  fi
  if [[ "$(id -u)" -eq 0 ]]; then
    require_cmd runuser
    runuser -u "$context_user" -- env \
      HOME="$context_home" \
      XDG_CONFIG_HOME="$context_xdg_config_home" \
      XDG_DATA_HOME="$context_xdg_data_home" \
      XDG_CACHE_HOME="$context_xdg_cache_home" \
      XDG_STATE_HOME="$context_xdg_state_home" \
      XDG_RUNTIME_DIR="$context_runtime" \
      DBUS_SESSION_BUS_ADDRESS="$context_bus" \
      PATH="$PATH" \
      "$@"
    return $?
  fi
  require_cmd sudo
  sudo -u "$context_user" -- env \
    HOME="$context_home" \
    XDG_CONFIG_HOME="$context_xdg_config_home" \
    XDG_DATA_HOME="$context_xdg_data_home" \
    XDG_CACHE_HOME="$context_xdg_cache_home" \
    XDG_STATE_HOME="$context_xdg_state_home" \
    XDG_RUNTIME_DIR="$context_runtime" \
    DBUS_SESSION_BUS_ADDRESS="$context_bus" \
    PATH="$PATH" \
    "$@"
}

verify_managed_runner_once_is_active() {
  ensure_user_manager
  run_as_user /usr/bin/systemctl --user is-active --quiet gitlab-runner.service ||
    die "gitlab-runner-managed once returned success but gitlab-runner.service is not active for ${context_user}"
}

ensure_user_manager() {
  if [[ -S "${context_runtime}/bus" ]]; then
    return 0
  fi
  if [[ "$(id -un)" == "$context_user" ]]; then
    die "user manager bus is not ready for ${context_user}; log in normally or rerun with sudo/root"
  fi
  require_cmd loginctl
  require_cmd systemctl
  run_privileged loginctl enable-linger "$context_user" >/dev/null
  run_privileged systemctl start "user@${context_uid}.service" >/dev/null
  for _ in 1 2 3 4 5; do
    if [[ -S "${context_runtime}/bus" ]]; then
      run_as_user /usr/bin/systemctl --user daemon-reload >/dev/null 2>&1 || true
      return 0
    fi
    sleep 1
  done
  die "user manager bus did not become ready for ${context_user}"
}

is_systemctl_action() {
  local wanted="$1"
  local action
  for action in "${systemctl_actions[@]}"; do
    [[ "$wanted" == "$action" ]] && return 0
  done
  return 1
}

prepend_runner_user_flag_if_missing() {
  local -a source_args
  local arg
  local have_user_flag=false
  source_args=("$@")
  for arg in "${source_args[@]:1}"; do
    if [[ "$arg" == "--user" || "$arg" == --user=* ]]; then
      have_user_flag=true
      break
    fi
  done
  if [[ "$have_user_flag" == "true" ]]; then
    command_args=("${source_args[@]}")
  else
    command_args=("${source_args[0]}" "--user" "$context_user" "${source_args[@]:1}")
  fi
}

gitlab_runner_managed_subcommand() {
  local arg
  local skip_next=false
  for arg in "${@}"; do
    if [[ "$skip_next" == "true" ]]; then
      skip_next=false
      continue
    fi
    case "$arg" in
      --user)
        skip_next=true
        ;;
      --user=*)
        ;;
      *)
        printf '%s' "$arg"
        return 0
        ;;
    esac
  done
}

run_command() {
  local command_name="$1"
  local managed_subcommand=
  shift

  if is_systemctl_action "$command_name"; then
    ensure_user_manager
    run_as_user /usr/bin/systemctl --user "$command_name" "$@"
    return 0
  fi

  case "${command_name##*/}" in
    systemctl)
      ensure_user_manager
      if [[ "${1:-}" == "--user" ]]; then
        run_as_user "$command_name" "$@"
      else
        run_as_user "$command_name" --user "$@"
      fi
      ;;
    journalctl)
      run_as_user "$command_name" --user "$@"
      ;;
    podman)
      ensure_user_manager
      run_as_user "$command_name" "$@"
      ;;
    aptly-managed)
      run_privileged "$command_name" --runner-user "$context_user" "$@"
      ;;
    gitlab-runner-managed)
      prepend_runner_user_flag_if_missing "$command_name" "$@"
      managed_subcommand="$(gitlab_runner_managed_subcommand "${command_args[@]:1}")"
      if [[ "$managed_subcommand" == "once" || "$managed_subcommand" == "preflight" ]]; then
        ensure_user_manager
      fi
      run_privileged "${command_args[@]}"
      if [[ "$managed_subcommand" == "once" ]]; then
        verify_managed_runner_once_is_active
      fi
      ;;
    *)
      die "unsupported command: ${command_name}; allowed commands are systemctl actions, systemctl, journalctl, podman, aptly-managed, and gitlab-runner-managed"
      ;;
  esac
}

report_success() {
  local command_name="${command_args[0]}"
  local command_base="${command_name##*/}"
  local managed_subcommand=

  case "$command_base" in
    aptly-managed)
      info "aptly-managed ${command_args[1]:-command} succeeded for ${context_user}"
      ;;
    gitlab-runner-managed)
      managed_subcommand="$(gitlab_runner_managed_subcommand "${command_args[@]:1}")"
      info "gitlab-runner-managed ${managed_subcommand:-command} succeeded for ${context_user}"
      ;;
    systemctl)
      case "${command_args[1]:-}" in
        start|stop|restart|reload|enable|disable|reset-failed|daemon-reload|try-restart)
          info "systemctl --user ${command_args[1]} succeeded for ${context_user}"
          ;;
      esac
      ;;
    *)
      if is_systemctl_action "$command_name"; then
        case "$command_name" in
          start|stop|restart|reload|enable|disable|reset-failed|daemon-reload|try-restart)
            info "systemctl --user ${command_name} succeeded for ${context_user}"
            ;;
        esac
      fi
      ;;
  esac
}

usage() {
  cat >&2 <<EOF
usage: ${PROG} --user <managed-runner-user> COMMAND [ARGS...]

examples:
  ${PROG} --user glab-user status gitlab-runner.service
  ${PROG} --user glab-user podman ps
  ${PROG} --user glab-aptly /usr/local/sbin/gitlab-runner-managed once
  ${PROG} --user glab-aptly /usr/local/sbin/aptly-managed publish snapshot foo
EOF
}

parse_args() {
  [[ "$#" -ge 3 ]] || {
    usage
    exit 2
  }
  [[ "$1" == "--user" ]] || die "first argument must be --user"
  requested_user="$2"
  shift 2
  [[ "$#" -gt 0 ]] || die "missing command"
  command_args=("$@")
}

main() {
  parse_args "$@"
  load_user_context
  if run_command "${command_args[0]}" "${command_args[@]:1}"; then
    report_success
  else
    exit $?
  fi
}

main "$@"
