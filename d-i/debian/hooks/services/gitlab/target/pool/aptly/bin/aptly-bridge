#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'
shopt -s inherit_errexit 2>/dev/null || true

REQUESTS_DIR="${APTLY_BRIDGE_REQUESTS_DIR:-/pool/aptly/queue/requests}"
RESULTS_DIR="${APTLY_BRIDGE_RESULTS_DIR:-/pool/aptly/queue/results}"
WAIT_SECONDS="${APTLY_BRIDGE_WAIT_SECONDS:-1800}"
POLL_INTERVAL="${APTLY_BRIDGE_POLL_INTERVAL:-1}"

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

validate_dir() {
  local label="$1"
  local value="$2"
  [[ "$value" == /* ]] || die "${label} must be an absolute path"
  [[ -d "$value" && ! -L "$value" ]] || die "${label} is missing: ${value}"
  [[ -w "$value" && -x "$value" ]] || die "${label} is not writable/searchable: ${value}"
}

validate_positive_int() {
  local label="$1"
  local value="$2"
  [[ "$value" =~ ^[0-9]+$ ]] || die "${label} must be numeric"
  (( 10#$value >= 1 )) || die "${label} must be greater than zero"
}

submit_request() {
  local request_path request_id result_path
  local -a args=("$@")
  require_cmd python3
  require_cmd mktemp
  validate_dir REQUESTS_DIR "$REQUESTS_DIR"
  validate_dir RESULTS_DIR "$RESULTS_DIR"
  validate_positive_int WAIT_SECONDS "$WAIT_SECONDS"
  validate_positive_int POLL_INTERVAL "$POLL_INTERVAL"
  [[ "${#args[@]}" -ge 2 ]] || die "bridge submit requires an aptly publish command"

  request_path="$(mktemp "${REQUESTS_DIR%/}/request.XXXXXXXXXX.json")"
  request_id="${request_path##*/}"
  request_id="${request_id%.json}"
  result_path="${RESULTS_DIR%/}/${request_id}.json"

  python3 - "$request_path" "$request_id" "${args[@]}" <<'PY'
import json
import pathlib
import sys

request_path = pathlib.Path(sys.argv[1])
request_id = sys.argv[2]
args = sys.argv[3:]
if len(args) < 2:
    raise SystemExit("bridge publish request requires at least two args")
if args[0] != "publish":
    raise SystemExit("bridge only supports aptly publish requests")
if args[1] not in {"snapshot", "repo"}:
    raise SystemExit("bridge only supports aptly publish snapshot|repo")
for arg in args:
    if not arg:
        raise SystemExit("bridge args must not be empty")
    if len(arg) > 512:
        raise SystemExit(f"bridge arg too long: {arg[:64]}")
    if any(ord(ch) < 32 for ch in arg):
        raise SystemExit("bridge args contain unsupported control characters")
payload = {
    "version": 1,
    "request_id": request_id,
    "args": args,
}
request_path.write_text(json.dumps(payload, indent=2) + "\n")
PY
  chmod 0600 "$request_path"

  local waited=0
  while (( waited < 10#$WAIT_SECONDS )); do
    if [[ -f "$result_path" && ! -L "$result_path" ]]; then
      set +e
      python3 - "$result_path" <<'PY'
import json
import pathlib
import sys

result_path = pathlib.Path(sys.argv[1])
data = json.loads(result_path.read_text())
stdout = data.get("stdout", "")
stderr = data.get("stderr", "")
exit_code = int(data.get("exit_code", 1))
if stdout:
    sys.stdout.write(stdout)
if stderr:
    sys.stderr.write(stderr)
raise SystemExit(exit_code)
PY
      rc=$?
      set -e
      rm -f -- "$result_path"
      return "$rc"
    fi
    sleep "$POLL_INTERVAL"
    waited=$((waited + 10#$POLL_INTERVAL))
  done

  die "timed out waiting for Aptly publish bridge result: ${request_id}"
}

main() {
  [[ "${1:-}" == "submit" ]] || die "usage: aptly-bridge submit publish ..."
  shift
  submit_request "$@"
}

main "$@"
