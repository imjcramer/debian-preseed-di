#!/bin/sh
set -eu

fatal() {
  printf 'fatal: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fatal "required command is not installed: $1"
}

require_executable() {
  [ -x "$1" ] || fatal "required executable is not available: $1"
}

run_session_shutdown_hook() {
  shutdown_hook="${XDG_CONFIG_HOME:-${HOME}/.config}/labwc/shutdown"
  [ -x "$shutdown_hook" ] || return 0
  "$shutdown_hook" >/dev/null 2>&1 || true
}

action=${1:-}
[ -n "$action" ] || fatal "usage: labwc-admin-action <suspend|reboot|poweroff>"
shutdown_mode=keep-session

require_command systemctl
systemctl_cmd=$(command -v systemctl)
[ -n "$systemctl_cmd" ] || fatal "systemctl command lookup returned an empty path"
require_executable "$systemctl_cmd"

case "$action" in
  suspend)
    shift
    set -- "$systemctl_cmd" suspend "$@"
    ;;
  reboot)
    shutdown_mode=shutdown
    shift
    set -- "$systemctl_cmd" reboot "$@"
    ;;
  poweroff)
    shutdown_mode=shutdown
    shift
    set -- "$systemctl_cmd" poweroff "$@"
    ;;
  *)
    fatal "unsupported privileged desktop action: ${action}"
    ;;
esac

[ "$#" -ge 2 ] || fatal "no privileged command was selected"
if "$@"; then
  if [ "$shutdown_mode" = shutdown ]; then
    run_session_shutdown_hook
  fi
  exit 0
else
  command_status=$?
  exit "$command_status"
fi
