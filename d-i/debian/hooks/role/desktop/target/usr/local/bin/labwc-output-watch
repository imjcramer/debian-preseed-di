#!/bin/sh
set -eu

skip_initial_refresh=false
case "${1:-}" in
  '')
    ;;
  --skip-initial-refresh)
    skip_initial_refresh=true
    ;;
  *)
    printf 'usage: labwc-output-watch [--skip-initial-refresh]\n' >&2
    exit 2
    ;;
esac

if [ -r /etc/default/labwc-desktop ]; then
  # shellcheck disable=SC1091
  . /etc/default/labwc-desktop
fi

debounce_seconds=${LABWC_OUTPUT_HOTPLUG_DEBOUNCE_SECONDS:-2}

if [ "$skip_initial_refresh" != true ]; then
  labwc-output-refresh || true
fi

command -v udevadm >/dev/null 2>&1 || exit 0

udevadm monitor --subsystem-match=drm 2>/dev/null | while IFS= read -r event_line; do
  case "$event_line" in
    *' change '*|*' add '*|*' remove '*|*change*drm*|*add*drm*|*remove*drm*)
      sleep "$debounce_seconds"
      labwc-output-refresh || true
      ;;
  esac
done
