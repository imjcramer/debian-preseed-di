#!/bin/sh
set -eu

if [ -r /etc/default/labwc-desktop ]; then
  # shellcheck disable=SC1091
  . /etc/default/labwc-desktop
fi

desktop_enabled() {
  case "${1:-true}" in
    true|yes|1|on) return 0 ;;
    *) return 1 ;;
  esac
}

state_dir="${XDG_STATE_HOME:-${HOME}/.local/state}/labwc"
install -d -m 0700 "$state_dir"
log_path="${state_dir}/crystal-dock.log"
pid_path="${state_dir}/crystal-dock.pid"
lock_path="${state_dir}/crystal-dock.lock"

desktop_enabled "${LABWC_ENABLE_CRYSTAL_DOCK:-true}" || exit 0

dock_command=${LABWC_CRYSTAL_DOCK_COMMAND:-crystal-dock}
case "$dock_command" in
  ''|*[!ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789._+@%=:,/\ -]*)
    printf '%s invalid LABWC_CRYSTAL_DOCK_COMMAND: %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$dock_command" >>"$log_path"
    exit 1
    ;;
esac

dock_binary=${dock_command%% *}
dock_process=${dock_binary##*/}
dock_user_id=$(id -u)

timestamp() {
  date -u '+%Y-%m-%dT%H:%M:%SZ'
}

log_message() {
  printf '%s %s\n' "$(timestamp)" "$1" >>"$log_path"
}

clear_pid_file() {
  rm -f "$pid_path"
}

dock_pid_is_running() {
  dock_pid=$1
  [ -n "$dock_pid" ] || return 1
  kill -0 "$dock_pid" >/dev/null 2>&1 || return 1
  command -v ps >/dev/null 2>&1 || return 0
  running_comm=$(ps -p "$dock_pid" -o comm= 2>/dev/null | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' || true)
  [ "$running_comm" = "$dock_process" ]
}

read_pid_file() {
  [ -r "$pid_path" ] || return 1
  IFS= read -r dock_pid <"$pid_path" || return 1
  [ -n "$dock_pid" ] || return 1
  printf '%s\n' "$dock_pid"
}

with_lock() {
  if ! command -v flock >/dev/null 2>&1; then
    "$@"
    return
  fi

  (
    exec 9>"$lock_path"
    flock -w 5 9 || exit 0
    "$@"
  )
}

stop_running_dock() {
  dock_pid=$(read_pid_file 2>/dev/null || true)
  if [ -n "$dock_pid" ] && dock_pid_is_running "$dock_pid"; then
    kill "$dock_pid" >/dev/null 2>&1 || true
  else
    pkill -u "$dock_user_id" -x "$dock_process" >/dev/null 2>&1 || true
  fi
  clear_pid_file
}

start_dock_process() {
  set -f
  # The validated command string intentionally contains only simple argv tokens.
  # shellcheck disable=SC2086
  set -- $dock_command
  set +f

  (
    exec 9>&- 2>/dev/null || true
    export XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-labwc:wlroots}"
    export QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-wayland}"
    export QT_QPA_PLATFORMTHEME="${QT_QPA_PLATFORMTHEME:-qt6ct}"
    export QT_STYLE_OVERRIDE="${QT_STYLE_OVERRIDE:-adwaita-dark}"
    exec >>"$log_path" 2>&1
    exec "$@"
  ) &
  dock_pid=$!
  printf '%s\n' "$dock_pid" >"$pid_path"
}

start_if_needed_locked() {
  dock_pid=$(read_pid_file 2>/dev/null || true)
  if [ -n "$dock_pid" ] && dock_pid_is_running "$dock_pid"; then
    return 0
  fi

  clear_pid_file
  if command -v pgrep >/dev/null 2>&1 &&
     pgrep -u "$dock_user_id" -x "$dock_process" >/dev/null 2>&1; then
    return 0
  fi

  start_dock_process
}

restart_locked() {
  stop_running_dock
  sleep "${LABWC_CRYSTAL_DOCK_RESTART_DELAY_SECONDS:-1}"
  start_if_needed_locked
}

if ! command -v "$dock_binary" >/dev/null 2>&1; then
  log_message 'missing crystal-dock binary'
  exit 0
fi

case "${1:-}" in
  --stop)
    with_lock stop_running_dock
    exit 0
    ;;
  --restart)
    with_lock restart_locked
    exit 0
    ;;
  '')
    with_lock start_if_needed_locked
    exit 0
    ;;
  *)
    log_message "unsupported labwc-dock argument: $1"
    exit 1
    ;;
esac
