#!/bin/sh
set -eu

if [ -r /etc/default/labwc-desktop ]; then
  # shellcheck disable=SC1091
  . /etc/default/labwc-desktop
fi

layout_list=${LABWC_KEYBOARD_LAYOUTS:-us se}
default_layout=${LABWC_KEYBOARD_DEFAULT_LAYOUT:-us}
state_dir="${XDG_STATE_HOME:-${HOME}/.local/state}/labwc"
state_file="${state_dir}/keyboard-layout"
env_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/labwc/environment.d"
env_file="${env_dir}/20-keyboard-layout.env"

normalize_layout() {
  case "$1" in
    us) printf '%s\n' us ;;
    se|sv) printf '%s\n' se ;;
    *) return 1 ;;
  esac
}

layout_is_allowed() {
  wanted=$(normalize_layout "$1" 2>/dev/null || true)
  [ -n "$wanted" ] || return 1

  for candidate in $layout_list; do
    candidate=$(normalize_layout "$candidate" 2>/dev/null || true)
    [ -n "$candidate" ] || continue
    [ "$candidate" = "$wanted" ] && return 0
  done
  return 1
}

current_layout() {
  layout=
  if [ -r "$state_file" ]; then
    IFS= read -r layout <"$state_file" || layout=
  fi
  layout=$(normalize_layout "${layout:-$default_layout}" 2>/dev/null || true)
  if [ -n "$layout" ] && layout_is_allowed "$layout"; then
    printf '%s\n' "$layout"
    return 0
  fi

  layout=$(normalize_layout "$default_layout" 2>/dev/null || true)
  [ -n "$layout" ] && layout_is_allowed "$layout" || layout=us
  printf '%s\n' "$layout"
}

next_layout() {
  current=$1
  previous=
  first=

  for candidate in $layout_list; do
    candidate=$(normalize_layout "$candidate" 2>/dev/null || true)
    [ -n "$candidate" ] || continue
    [ -n "$first" ] || first=$candidate
    if [ "$previous" = "$current" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
    previous=$candidate
  done

  printf '%s\n' "${first:-us}"
}

write_layout_state() {
  layout=$1
  umask 077
  install -d -m 0700 "$state_dir" "$env_dir"
  state_tmp="${state_file}.$$"
  env_tmp="${env_file}.$$"
  trap 'rm -f "$state_tmp" "$env_tmp"' EXIT HUP INT TERM
  printf '%s\n' "$layout" >"$state_tmp"
  {
    printf '# Generated by labwc-keyboard-layout.\n'
    printf 'XKB_DEFAULT_LAYOUT=%s\n' "$layout"
  } >"$env_tmp"
  mv "$state_tmp" "$state_file"
  mv "$env_tmp" "$env_file"
  trap - EXIT HUP INT TERM
}

reconfigure_labwc() {
  [ -n "${WAYLAND_DISPLAY:-}" ] || return 0
  command -v labwc >/dev/null 2>&1 || return 0
  labwc --reconfigure >/dev/null 2>&1 || true
}

layout_label() {
  case "$1" in
    se) printf '%s\n' SE ;;
    *) printf '%s\n' US ;;
  esac
}

layout_flag() {
  case "$1" in
    se) printf '%s\n' '🇸🇪' ;;
    *) printf '%s\n' '🇺🇸' ;;
  esac
}

print_status_json() {
  layout=$(current_layout)
  label=$(layout_label "$layout")
  flag=$(layout_flag "$layout")
  printf '{"text":"%s","tooltip":"Keyboard layout: %s","class":"%s"}\n' "$flag" "$label" "$layout"
}

case "${1:-status}" in
  status|json)
    print_status_json
    ;;
  current)
    current_layout
    ;;
  toggle)
    layout=$(next_layout "$(current_layout)")
    write_layout_state "$layout"
    reconfigure_labwc
    print_status_json
    ;;
  set)
    layout=$(normalize_layout "${2:-}" 2>/dev/null || true)
    [ -n "$layout" ] && layout_is_allowed "$layout" || {
      printf 'fatal: unsupported keyboard layout: %s\n' "${2:-unset}" >&2
      exit 1
    }
    write_layout_state "$layout"
    reconfigure_labwc
    print_status_json
    ;;
  *)
    printf 'usage: labwc-keyboard-layout [status|current|toggle|set <us|se>]\n' >&2
    exit 2
    ;;
esac
