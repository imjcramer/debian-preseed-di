#!/bin/sh
set -eu

for process_name in waybar kanshi mako swayidle; do
  pkill -x "$process_name" >/dev/null 2>&1 || true
done

if command -v labwc-dock >/dev/null 2>&1; then
  labwc-dock --stop >/dev/null 2>&1 || true
fi

unmount_gvfs_fuse() {
  [ -n "${XDG_RUNTIME_DIR:-}" ] || return 0
  gvfs_mount="${XDG_RUNTIME_DIR}/gvfs"
  [ -e "$gvfs_mount" ] || return 0

  if command -v fusermount3 >/dev/null 2>&1; then
    fusermount3 -u "$gvfs_mount" >/dev/null 2>&1 ||
      fusermount3 -uz "$gvfs_mount" >/dev/null 2>&1 ||
      true
    return 0
  fi
  if command -v fusermount >/dev/null 2>&1; then
    fusermount -u "$gvfs_mount" >/dev/null 2>&1 ||
      fusermount -uz "$gvfs_mount" >/dev/null 2>&1 ||
      true
  fi
}

if command -v gio >/dev/null 2>&1; then
  gio mount -a -u >/dev/null 2>&1 || true
fi
unmount_gvfs_fuse

if command -v wl-copy >/dev/null 2>&1; then
  wl-copy --clear >/dev/null 2>&1 || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user stop \
    graphical-session.target \
    labwc-session.target \
    labwc-calendar-sync.service \
    labwc-calendar-sync.timer \
    hyprpolkitagent.service \
    wireplumber.service \
    pipewire.service \
    pipewire-pulse.service \
    pipewire.socket \
    pipewire-pulse.socket \
    xdg-desktop-portal-gtk.service \
    xdg-desktop-portal-wlr.service \
    xdg-desktop-portal-lxqt.service \
    xdg-desktop-portal-xapp.service \
    xdg-desktop-portal.service >/dev/null 2>&1 || true
fi

for process_name in hyprpolkitagent ksecretd gvfsd gvfsd-fuse gvfs-udisks2-volume-monitor; do
  pkill -x "$process_name" >/dev/null 2>&1 || true
done

sync >/dev/null 2>&1 || true
