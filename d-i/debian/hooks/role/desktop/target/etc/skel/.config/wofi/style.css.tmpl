@define-color bg #08111f;
@define-color bg_alt #101d33;
@define-color bg_hover #1b2c44;
@define-color glow rgba(236, 184, 96, 0.16);
@define-color border rgba(236, 184, 96, 0.28);
@define-color border_strong rgba(236, 184, 96, 0.72);
@define-color text #f5efe3;
@define-color muted #aeb7c6;
@define-color amber #ecb860;
@define-color amber_bold #f29f67;
@define-color mint #9fd2bf;
@define-color rose #f6a09a;

window {
  margin: 0;
  padding: 16px;
  border: 1px solid @border_strong;
  border-radius: 20px;
  background:
    linear-gradient(135deg, rgba(18, 30, 50, 0.96), rgba(8, 17, 31, 0.98)),
    rgba(8, 17, 31, 0.98);
  color: @text;
  font-family: "Noto Sans", "Noto Color Emoji", "Font Awesome 6 Free";
  font-size: __INSTALLER_LABWC_WOFI_FONT_SIZE__px;
  box-shadow:
    0 18px 48px rgba(0, 0, 0, 0.48),
    0 0 0 8px rgba(12, 16, 23, 0.16);
}

#outer-box {
  padding: 2px;
}

#inner-box {
  padding: 2px;
}

#input {
  margin: 0 0 12px 0;
  padding: 12px 16px;
  border: 1px solid @border;
  border-radius: 14px;
  background:
    linear-gradient(90deg, rgba(16, 29, 51, 0.96), rgba(27, 44, 68, 0.88));
  color: #ffffff;
  caret-color: @amber;
  box-shadow: 0 0 0 3px @glow;
}

#input:focus {
  border-color: @border_strong;
}

#entry {
  margin: 3px 0;
  padding: 10px 12px;
  border: 1px solid transparent;
  border-radius: 12px;
  color: @text;
}

#entry:hover {
  background-color: @bg_hover;
  border-color: @border;
}

#entry:selected {
  background: linear-gradient(135deg, @amber, @amber_bold 56%, #f5b37a);
  border-color: rgba(255, 255, 255, 0.42);
  color: #08111f;
  box-shadow: 0 8px 22px rgba(236, 184, 96, 0.22);
}

#img {
  margin-right: 10px;
  border-radius: 10px;
}

#text {
  color: inherit;
}

#scroll {
  margin: 0;
}

scrollbar {
  border: none;
  background: transparent;
}

scrollbar slider {
  min-width: 6px;
  min-height: 32px;
  border-radius: 999px;
  background: linear-gradient(180deg, @amber, @amber_bold);
}
