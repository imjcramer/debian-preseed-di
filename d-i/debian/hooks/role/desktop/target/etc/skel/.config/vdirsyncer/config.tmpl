[general]
status_path = "~/.local/state/vdirsyncer/status/"

[pair fruux_calendar]
a = "fruux_calendar_local"
b = "fruux_calendar_remote"
collections = null

[storage fruux_calendar_local]
type = "filesystem"
path = "~/.local/share/calendars/personal"
fileext = ".ics"

[storage fruux_calendar_remote]
type = "caldav"
url = "__INSTALLER_FRUUX_CALENDAR_URL__"
username = "__INSTALLER_FRUUX_USERNAME__"
password = "__INSTALLER_FRUUX_PASSWORD__"
item_types = ["VEVENT"]

[pair fruux_tasks]
a = "fruux_tasks_local"
b = "fruux_tasks_remote"
collections = null

[storage fruux_tasks_local]
type = "filesystem"
path = "~/.local/share/calendars/tasks"
fileext = ".ics"

[storage fruux_tasks_remote]
type = "caldav"
url = "__INSTALLER_FRUUX_TASKS_URL__"
username = "__INSTALLER_FRUUX_USERNAME__"
password = "__INSTALLER_FRUUX_PASSWORD__"
item_types = ["VTODO"]
