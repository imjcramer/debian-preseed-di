#!/bin/sh
# Base-installer hook: guarantee a usable /target/etc/fstab before debootstrap
# mutates fstab placeholders.
set -eu

RUNTIME_DIR=${INSTALLER_RUNTIME_DIR:-/tmp/install-runtime}
RUNTIME_LOG_DIR=${INSTALLER_LOG_DIR:-${INSTALLER_PRESEED_LOG_DIR:-/tmp/preseed-logs}}
COMMON_LIB="${RUNTIME_DIR}/bootstrap/common-lib.sh"
DEBUG_LOGS=0

if [ -r "$COMMON_LIB" ]; then
  # shellcheck disable=SC1090
  . "$COMMON_LIB"
  LOG=$(installer_resolve_runtime_log_path "${RUNTIME_LOG_DIR}/05-partman.log")
  if command -v installer_export_logging_policy >/dev/null 2>&1; then
    installer_export_logging_policy
  fi
  if command -v installer_logging_enabled >/dev/null 2>&1 && installer_logging_enabled; then
    DEBUG_LOGS=1
  fi
else
  LOG="${RUNTIME_LOG_DIR}/05-partman.log"
fi

if [ "$DEBUG_LOGS" -eq 1 ]; then
  mkdir -p "$(dirname "$LOG")"
  : >>"$LOG"
  chmod 0600 "$LOG" 2>/dev/null || true
  exec >>"$LOG" 2>&1
fi

TARGET=/target
FSTAB="${TARGET}/etc/fstab"
FSTAB_CACHE="${TARGET}/etc/fstab.layout-cache"
TMP_FSTAB="/tmp/base-installer-fstab.$$"

log() {
  level=info
  message=$*
  case "$message" in
    fatal:\ *) level=fatal; message=${message#fatal: } ;;
    error:\ *) level=error; message=${message#error: } ;;
    warn:\ *) level=warn; message=${message#warn: } ;;
    info:\ *) level=info; message=${message#info: } ;;
  esac
  if [ "$DEBUG_LOGS" -ne 1 ]; then
    case "$level" in fatal|error) ;; *) return 0 ;; esac
  fi
  printf '%s stage=base_install_start level=%s component=base-installer-fstab %s\n' \
    "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || printf unknown-time)" \
    "$level" \
    "$message" >&2
}

target_is_mounted() {
  while IFS=' ' read -r _mount_source mount_path _mount_type _mount_options _mount_rest || [ -n "${mount_path:-}" ]; do
    [ "$mount_path" = "$TARGET" ] && return 0
  done </proc/mounts
  return 1
}

fstab_has_root_entry() {
  fstab_path=$1

  [ -r "$fstab_path" ] || return 1
  while IFS=' ' read -r _fstab_source mount_path _fstab_type _fstab_rest || [ -n "${mount_path:-}" ]; do
    case "$mount_path" in
      ''|'#'*) continue ;;
    esac
    [ "$mount_path" = "/" ] && return 0
  done <"$fstab_path"
  return 1
}

persist_log() {
  return 0
}

finish_log() {
  status=${1:-0}
  if [ "$status" -eq 0 ]; then
    log "info: completed base-installer fstab guard"
  else
    log "error: base-installer fstab guard exited with status ${status}"
  fi
  persist_log
}

trap 'finish_log "$?"' EXIT

if [ ! -d "$TARGET" ]; then
  exit 0
fi

if [ -s "$FSTAB" ] && ! grep -q 'UNCONFIGURED FSTAB' "$FSTAB" 2>/dev/null; then
  log "info: fstab already configured at $FSTAB"
  exit 0
fi

mkdir -p "${TARGET}/etc"

if [ -s "$FSTAB_CACHE" ] && fstab_has_root_entry "$FSTAB_CACHE"; then
  install -m 0644 "$FSTAB_CACHE" "$FSTAB"
  cp "$FSTAB" "${TARGET}/etc/fstab.orig" 2>/dev/null || true
  echo "info: restored target fstab from ${FSTAB_CACHE}"
  exit 0
fi

{
  echo "# Generated by installer automation base-installer fstab guard (mount scan)"
  echo
  echo "# Pseudo filesystems"
  printf '%-28s %-36s %-8s %-72s 0 0\n' "proc" "/proc" "proc" "defaults"
  echo
  echo "# Reconstructed target mounts"
  seen_keys=' '
  while IFS=' ' read -r mount_source mount_path mount_type mount_options _mount_rest || [ -n "${mount_source:-}" ]; do
    case "$mount_path" in
      /target|/target/*) ;;
      *) continue ;;
    esac
    mount_path=${mount_path#/target}
    [ -n "$mount_path" ] || mount_path=/
    case "$mount_path" in
      /dev|/dev/*|/proc|/proc/*|/sys|/sys/*|/run|/run/*)
        continue
        ;;
    esac
    case "$mount_source" in
      /dev/*|tmpfs) ;;
      *) continue ;;
    esac
    case "$mount_type" in
      btrfs|ext4|f2fs|vfat|xfs|tmpfs) ;;
      *) continue ;;
    esac
    key="${mount_source}|${mount_path}"
    case " ${seen_keys} " in
      *" ${key} "*) continue ;;
      *) seen_keys="${seen_keys}${key} " ;;
    esac
    dump=0
    pass=0
    case "$mount_type:$mount_path" in
      btrfs:/) pass=0 ;;
      ext4:/|f2fs:/) pass=1 ;;
      vfat:*|ext4:*|f2fs:*) pass=2 ;;
    esac
    printf '%-28s %-36s %-8s %-72s %d %d\n' "$mount_source" "$mount_path" "$mount_type" "$mount_options" "$dump" "$pass"
  done </proc/mounts
} >"$TMP_FSTAB"

if ! fstab_has_root_entry "$TMP_FSTAB"; then
  log "warn: no root mount detected under /target; skipping fstab guard"
  rm -f "$TMP_FSTAB"
  exit 0
fi

install -m 0644 "$TMP_FSTAB" "$FSTAB"
cp "$FSTAB" "$FSTAB_CACHE" 2>/dev/null || true
cp "$FSTAB" "${TARGET}/etc/fstab.orig" 2>/dev/null || true
rm -f "$TMP_FSTAB"

log "info: wrote fallback target fstab at $FSTAB"
