# Managed by debian-preseed-di.

#include <tunables/global>

profile apt-cacher-ng /usr/sbin/apt-cacher-ng flags=(attach_disconnected, complain) {
  #include <abstractions/base>
  include if exists <abstractions/nameservice>
  include if exists <abstractions/ssl_certs>

  capability chown,
  capability dac_read_search,
  capability fowner,
  capability setgid,
  capability setuid,

  /usr/sbin/apt-cacher-ng mr,
  /usr/lib/apt-cacher-ng/** mr,
  /usr/share/apt-cacher-ng/** r,
  /usr/share/doc/apt-cacher-ng/** r,
  /etc/apt-cacher-ng/** r,
  /etc/apt/** r,
  /etc/ssl/certs/** r,

  /var/cache/apt-cacher-ng/** rwk,
  /var/log/apt-cacher-ng/** rw,
  /run/apt-cacher-ng/** rwk,
  /var/run/apt-cacher-ng/** rwk,
  /tmp/** rwk,

  include if exists <local/usr.sbin.apt-cacher-ng>
}
