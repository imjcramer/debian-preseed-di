// Managed by debian-preseed-di.
// Permit only narrow local radio toggles to netdev; system networking is sudo-only.

(function() {
    var ADMIN_GROUP = "sudo";
    var NETWORK_GROUP = "netdev";

    function startsWith(value, prefix) {
        return typeof value === "string" && value.indexOf(prefix) === 0;
    }

    function inList(value, list) {
        var i;
        for (i = 0; i < list.length; i++) {
            if (value === list[i]) {
                return true;
            }
        }
        return false;
    }

    function activeLocal(subject) {
        if (subject.active !== true) {
            return false;
        }
        return subject.local === true ||
            (typeof subject.seat === "string" && subject.seat.length > 0);
    }

    function adminOnly(subject) {
        if (!activeLocal(subject)) {
            return polkit.Result.NO;
        }
        if (!subject.isInGroup(ADMIN_GROUP)) {
            return polkit.Result.NO;
        }
        return polkit.Result.AUTH_ADMIN;
    }

    polkit.addRule(function(action, subject) {
        var id = action.id;
        var userToggleActions = [
            "org.freedesktop.NetworkManager.enable-disable-network",
            "org.freedesktop.NetworkManager.enable-disable-wifi",
            "org.freedesktop.NetworkManager.enable-disable-wwan",
            "org.freedesktop.NetworkManager.enable-disable-wimax",
            "org.freedesktop.NetworkManager.sleep-wake"
        ];

        if (!startsWith(id, "org.freedesktop.NetworkManager.")) {
            return polkit.Result.NOT_HANDLED;
        }

        if (!activeLocal(subject)) {
            return polkit.Result.NO;
        }

        if (inList(id, userToggleActions) && subject.isInGroup(NETWORK_GROUP)) {
            return polkit.Result.YES;
        }

        return adminOnly(subject);
    });
})();
