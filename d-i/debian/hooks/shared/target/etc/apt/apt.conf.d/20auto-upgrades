// Managed by debian-preseed-di.
//
// Keep package metadata fresh and let unattended-upgrades apply eligible
// security/stable updates. The work is intentionally left to apt's timers so
// first boot is not blocked by package maintenance.

APT::Periodic::Enable "1";
APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Download-Upgradeable-Packages "1";
APT::Periodic::Unattended-Upgrade "1";
APT::Periodic::AutocleanInterval "7";
APT::Periodic::Verbose "0";
APT::Periodic::RandomSleep "1800";
