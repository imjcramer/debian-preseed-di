# Generated by installer automation.
# Installed as /etc/sudoers.d/__INSTALLER_ACCOUNT_USERNAME__.
#
# The daily account keeps ordinary sudo behind a password. The NOPASSWD
# allowance is intentionally limited to read-only system inspection helpers
# plus the narrow podbin start/connect workflow.

Cmnd_Alias READONLY_SYSTEM_INSPECTION = \
    /usr/bin/systemctl --no-pager status, \
    /usr/bin/systemctl --no-pager status *, \
    /usr/bin/systemctl --no-pager list-units --failed, \
    /usr/bin/systemctl --no-pager list-timers --all, \
    /usr/bin/journalctl --no-pager -n 200, \
    /usr/bin/journalctl --no-pager -u * -n 200, \
    /usr/bin/dmesg, \
    /usr/bin/dmesg -T, \
    /usr/bin/ss -tulpn

Cmnd_Alias PODBIN_DAILY_OPERATIONS = \
    /usr/local/sbin/podbin --start-container *, \
    /usr/local/sbin/podbin --connect-container *

Defaults:__INSTALLER_ACCOUNT_USERNAME__ env_reset
Defaults:__INSTALLER_ACCOUNT_USERNAME__ mail_badpass
Defaults:__INSTALLER_ACCOUNT_USERNAME__ passwd_timeout=1
Defaults:__INSTALLER_ACCOUNT_USERNAME__ timestamp_timeout=5

__INSTALLER_ACCOUNT_USERNAME__ ALL=(ALL:ALL) PASSWD: ALL
__INSTALLER_ACCOUNT_USERNAME__ ALL=(root) NOPASSWD: READONLY_SYSTEM_INSPECTION, PODBIN_DAILY_OPERATIONS
