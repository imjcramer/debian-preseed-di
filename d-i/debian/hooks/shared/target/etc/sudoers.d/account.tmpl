# Generated by installer automation.
# Installed as /etc/sudoers.d/__INSTALLER_ACCOUNT_USERNAME__.
#
# The daily account keeps ordinary sudo behind a password. The NOPASSWD
# allowance is intentionally limited to read-only system inspection helpers,
# low-risk podbin container access, and read-only managed rootless Podman
# inspection. Mutating Podman service-account actions still require ordinary
# password-backed sudo.

Cmnd_Alias READONLY_SYSTEM_INSPECTION = \
    /usr/bin/systemctl --no-pager status, \
    /usr/bin/systemctl --no-pager status *, \
    /usr/bin/systemctl --no-pager list-units --failed, \
    /usr/bin/systemctl --no-pager list-timers --all, \
    /usr/bin/journalctl --no-pager -n 200, \
    /usr/bin/journalctl --no-pager -u * -n 200, \
    /usr/bin/dmesg, \
    /usr/bin/dmesg -T, \
    /usr/bin/ss -tulpn

Cmnd_Alias PODBIN_DAILY_OPERATIONS = \
    /usr/local/sbin/podbin --start-container *, \
    /usr/local/sbin/podbin --connect-container *, \
    /usr/local/sbin/podbin --open-container *

Cmnd_Alias PODMAN_SERVICE_INSPECTION = \
    /usr/local/sbin/podbin --service-env, \
    /usr/local/sbin/podbin --service-podman info, \
    /usr/local/sbin/podbin --service-podman version, \
    /usr/local/sbin/podbin --service-podman ps, \
    /usr/local/sbin/podbin --service-podman ps *, \
    /usr/local/sbin/podbin --service-podman images, \
    /usr/local/sbin/podbin --service-podman images *, \
    /usr/local/sbin/podbin --service-podman image ls, \
    /usr/local/sbin/podbin --service-podman image ls *, \
    /usr/local/sbin/podbin --service-podman inspect *, \
    /usr/local/sbin/podbin --service-podman port *, \
    /usr/local/sbin/podbin --service-podman logs *, \
    /usr/local/sbin/podbin --service-podman stats --no-stream *, \
    /usr/local/sbin/podbin --service-podman network ls, \
    /usr/local/sbin/podbin --service-podman network ls *, \
    /usr/local/sbin/podbin --service-podman volume ls, \
    /usr/local/sbin/podbin --service-podman volume ls *, \
    /usr/local/sbin/podbin --service-podman pod ls, \
    /usr/local/sbin/podbin --service-podman pod ls *, \
    /usr/local/sbin/podbin --service-systemctl status *, \
    /usr/local/sbin/podbin --service-systemctl show *, \
    /usr/local/sbin/podbin --service-systemctl cat *, \
    /usr/local/sbin/podbin --service-systemctl is-active *, \
    /usr/local/sbin/podbin --service-systemctl list-units, \
    /usr/local/sbin/podbin --service-systemctl list-units *, \
    /usr/local/sbin/podbin --service-systemctl list-timers, \
    /usr/local/sbin/podbin --service-systemctl list-timers *, \
    /usr/local/sbin/podbin --service-journalctl -n 200, \
    /usr/local/sbin/podbin --service-journalctl -u * -n 200

Defaults:__INSTALLER_ACCOUNT_USERNAME__ env_reset
Defaults:__INSTALLER_ACCOUNT_USERNAME__ mail_badpass
Defaults:__INSTALLER_ACCOUNT_USERNAME__ passwd_timeout=1
Defaults:__INSTALLER_ACCOUNT_USERNAME__ timestamp_timeout=5

__INSTALLER_ACCOUNT_USERNAME__ ALL=(ALL:ALL) PASSWD: ALL
__INSTALLER_ACCOUNT_USERNAME__ ALL=(root) NOPASSWD: READONLY_SYSTEM_INSPECTION, PODBIN_DAILY_OPERATIONS, PODMAN_SERVICE_INSPECTION
