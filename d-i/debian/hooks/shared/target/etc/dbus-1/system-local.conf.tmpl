<!DOCTYPE busconfig PUBLIC "-//freedesktop//DTD D-Bus Bus Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/busconfig.dtd">
<busconfig>
  <!-- Managed by installer late_command. Standard D-Bus XML, broker-compatible. -->
  <limit name="max_incoming_bytes">__INSTALLER_DBUS_LIMIT_MAX_INCOMING_BYTES__</limit>
  <limit name="max_outgoing_bytes">__INSTALLER_DBUS_LIMIT_MAX_OUTGOING_BYTES__</limit>
  <limit name="max_message_size">__INSTALLER_DBUS_LIMIT_MAX_MESSAGE_SIZE__</limit>
  <limit name="max_message_unix_fds">__INSTALLER_DBUS_LIMIT_MAX_MESSAGE_UNIX_FDS__</limit>
  <limit name="max_incoming_unix_fds">__INSTALLER_DBUS_LIMIT_MAX_INCOMING_UNIX_FDS__</limit>
  <limit name="max_outgoing_unix_fds">__INSTALLER_DBUS_LIMIT_MAX_OUTGOING_UNIX_FDS__</limit>
  <limit name="max_match_rules_per_connection">__INSTALLER_DBUS_LIMIT_MAX_MATCH_RULES_PER_CONNECTION__</limit>
  <limit name="max_names_per_connection">__INSTALLER_DBUS_LIMIT_MAX_NAMES_PER_CONNECTION__</limit>
  <limit name="max_replies_per_connection">__INSTALLER_DBUS_LIMIT_MAX_REPLIES_PER_CONNECTION__</limit>
  <limit name="max_incomplete_connections">__INSTALLER_DBUS_LIMIT_MAX_INCOMPLETE_CONNECTIONS__</limit>
  <limit name="max_completed_connections">__INSTALLER_DBUS_LIMIT_MAX_COMPLETED_CONNECTIONS__</limit>
  <limit name="max_connections_per_user">__INSTALLER_DBUS_LIMIT_MAX_CONNECTIONS_PER_USER__</limit>
  <limit name="max_pending_service_starts">__INSTALLER_DBUS_LIMIT_MAX_PENDING_SERVICE_STARTS__</limit>
  <limit name="auth_timeout">__INSTALLER_DBUS_LIMIT_AUTH_TIMEOUT_MS__</limit>
  <limit name="pending_fd_timeout">__INSTALLER_DBUS_LIMIT_PENDING_FD_TIMEOUT_MS__</limit>
  <limit name="service_start_timeout">__INSTALLER_DBUS_LIMIT_SERVICE_START_TIMEOUT_MS__</limit>
  <limit name="reply_timeout">__INSTALLER_DBUS_LIMIT_REPLY_TIMEOUT_MS__</limit>
</busconfig>
