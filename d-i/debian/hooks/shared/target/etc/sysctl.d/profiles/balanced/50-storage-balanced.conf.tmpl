fs.aio-max-nr = __INSTALLER_SYSCTL_PROFILE_BALANCED_AIO_MAX_NR__
fs.inotify.max_user_instances = __INSTALLER_SYSCTL_PROFILE_BALANCED_INOTIFY_MAX_USER_INSTANCES__
