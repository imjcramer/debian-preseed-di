fs.inotify.max_queued_events = __INSTALLER_SYSCTL_PROFILE_BALANCED_INOTIFY_MAX_QUEUED_EVENTS__

# Network accept queues and connection churn.
net.core.somaxconn = __INSTALLER_SYSCTL_PROFILE_BALANCED_SOMAXCONN__
