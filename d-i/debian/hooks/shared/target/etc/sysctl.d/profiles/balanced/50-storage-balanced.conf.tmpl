# /etc/sysctl.d/profiles/balanced/50-storage-balanced.conf (rendered storage profile overlay)

# VM reclaim and zram-backed swap behavior.
vm.swappiness = __INSTALLER_SYSCTL_PROFILE_BALANCED_SWAPPINESS__
vm.page-cluster = __INSTALLER_SYSCTL_PROFILE_BALANCED_PAGE_CLUSTER__
vm.vfs_cache_pressure = __INSTALLER_SYSCTL_PROFILE_BALANCED_VFS_CACHE_PRESSURE__
vm.watermark_boost_factor = __INSTALLER_SYSCTL_PROFILE_BALANCED_WATERMARK_BOOST_FACTOR__
vm.watermark_scale_factor = __INSTALLER_SYSCTL_PROFILE_BALANCED_WATERMARK_SCALE_FACTOR__
vm.compaction_proactiveness = __INSTALLER_SYSCTL_PROFILE_BALANCED_COMPACTION_PROACTIVENESS__
vm.extfrag_threshold = __INSTALLER_SYSCTL_PROFILE_BALANCED_EXTFRAG_THRESHOLD__
vm.zone_reclaim_mode = __INSTALLER_SYSCTL_PROFILE_BALANCED_ZONE_RECLAIM_MODE__

# Dirty writeback budget for volatile caches and installer-managed storage.
vm.dirty_background_bytes = __INSTALLER_SYSCTL_PROFILE_BALANCED_DIRTY_BACKGROUND_BYTES__
vm.dirty_bytes = __INSTALLER_SYSCTL_PROFILE_BALANCED_DIRTY_BYTES__
