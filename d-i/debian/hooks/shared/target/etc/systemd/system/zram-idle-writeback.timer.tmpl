[Unit]
Description=Schedule idle zram writeback
After=__INSTALLER_ZRAM_SETUP_UNIT__
Requires=__INSTALLER_ZRAM_SETUP_UNIT__
ConditionPathExists=__INSTALLER_FILE_ZRAM_CONFIG__
ConditionPathExists=__INSTALLER_FILE_ZRAM_WRITEBACK_HELPER__

[Timer]
OnBootSec=10min
OnUnitActiveSec=__INSTALLER_ZRAM_IDLE_WRITEBACK_INTERVAL__
RandomizedDelaySec=__INSTALLER_ZRAM_IDLE_WRITEBACK_RANDOMIZED_DELAY__
AccuracySec=1min
Unit=zram-writeback.service
Persistent=true

[Install]
WantedBy=timers.target
