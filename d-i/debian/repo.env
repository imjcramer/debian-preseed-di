# APT preference defaults.
# Used only when no selected class metadata in `classes/configs/*.cfg` defines
# `debian_apt_preferences`.
DEBIAN_APT_PREFERENCES="sid,forky,dbus,x11"

# Repository-relative directories consumed by installer path resolution.
DIR_HOSTS_PROFILES="hosts/profiles"
DIR_HOSTS_SERVICES="hosts/services"
DIR_HOSTS_SHARED="hosts/shared"
DIR_HOOKS_HARDWARE_ARCH="hooks/hardware/arch"
DIR_HOOKS_HARDWARE_BLACKLIST="hooks/hardware/blacklist"
DIR_HOOKS_HARDWARE_CPU="hooks/hardware/cpu"
DIR_HOOKS_HARDWARE_DISK="hooks/hardware/disk"
DIR_HOOKS_HARDWARE_GPU="hooks/hardware/gpu"
DIR_HOOKS_ROLE_DESKTOP="hooks/role/desktop"
DIR_HOOKS_ROLE_SERVER="hooks/role/server"
DIR_HOOKS_SERVICES_GITLAB="hooks/services/gitlab"
DIR_HOOKS_SHARED_APT_SETUP_GENERATORS="hooks/shared/apt-setup"
DIR_HOOKS_SHARED_BASE_STAGE_D="hooks/shared/base-stage.d"
DIR_HOOKS_SHARED_D_I="hooks/shared/d-i"
DIR_HOOKS_SHARED_FINISH_INSTALL_D="hooks/shared/finish-install.d"
DIR_HOOKS_SHARED_PARTMAN="hooks/shared/partman"
DIR_HOOKS_SHARED_PARTMAN_FINISH_D="hooks/shared/partman/finish.d"
DIR_HOOKS_SHARED_TARGET="hooks/shared/target"
DIR_SCRIPTS_COMMON="scripts/common"
DIR_SCRIPTS_DESKTOP="scripts/desktop"
DIR_SCRIPTS_EARLY="scripts/early"
DIR_SCRIPTS_FIRSTBOOT="scripts/firstboot"
DIR_SCRIPTS_INITRAMFS="scripts/initramfs"
DIR_SCRIPTS_LATE="scripts/late"
DIR_SCRIPTS_PARTMAN="scripts/partman"
DIR_SCRIPTS_PRESEED="scripts/preseed"
DIR_SCRIPTS_RUNTIME="scripts/runtime"
